<li><a href="https://github.com/oh-my-fish/oh-my-fish">The Fishshell Framework</a><a data-role="trackawesomelist-badge" href="https://github.com/oh-my-fish/oh-my-fish" style="text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;"><span style="color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;"><span style="padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;">stars</span><span style="padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;">7.3k</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{"type":"repo","stargazerCount":7286,"repo":"oh-my-fish/oh-my-fish"}____TRACK_AWESOME_REPO_ITEM_END--> -
