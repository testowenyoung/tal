{"componentChunkName":"component---src-templates-awesome-timeline-js","path":"/inoue0426/awesome-computational-biology/","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"awesomeListMeta":{"readmeParsedAt":"2022-10-14T07:25:42.461Z","repo":"inoue0426/awesome-computational-biology","descriptionHTML":"<div>Awesome list of computational biology.</div>","description":"Awesome list of computational biology.","stargazerCount":10,"readmeItemsUpdatedTime":1652916284000,"category":"Miscellaneous"},"allAwesomeItem":{"nodes":[{"categoryHTML":"<h2>Databases</h2><h3>Compound</h3>","itemHTML":"<li><a href=\"https://www.ebi.ac.uk/chebi/\">ChEBI</a> - Chemical database  focused on small chemical compounds.</li>","updatedAt":"2022-05-18T23:24:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Protein</h3>","itemHTML":"<li><a href=\"https://www.rcsb.org/\">PROTEIN DATA BANK</a> - Database of the 3D shapes of proteins, nucleic acids, and complex assemblies.</li>","updatedAt":"2022-05-18T23:24:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Compound</h3>","itemHTML":"<li><a href=\"https://pubchem.ncbi.nlm.nih.gov/\">PubChem</a> - One of the biggest chemical database such as compounds, genes and proteins.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Compound</h3>","itemHTML":"<li><a href=\"https://www.ebi.ac.uk/chembl/\">ChEMBL</a> - Database of bioactive molecules with drug-like properties.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Compound</h3>","itemHTML":"<li><a href=\"http://www.chemspider.com/\">ChemSpider</a> - Chemical structure database.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Compound</h3>","itemHTML":"<li><a href=\"https://www.genome.jp/kegg/compound/\">KEGG COMPOUND</a> - Collection of small molecules and biopolymers.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Compound</h3>","itemHTML":"<li><a href=\"https://www.lipidmaps.org/databases/lmsd/overview\">LIPID MAPS</a> - Database of lipids.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Pathway</h3>","itemHTML":"<li><a href=\"https://www.pathwaycommons.org/\">PathwayCommon</a> - Database of Pathways and Interactions.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Pathway</h3>","itemHTML":"<li><a href=\"https://www.genome.jp/kegg/pathway.html\">KEGG PATHWAY</a> - Collection fo drawn pathway maps.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Pathway</h3>","itemHTML":"<li><a href=\"https://wikipathways.org/\">WikiPathways</a> - Database of biological pathways.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Mass Spectra</h3>","itemHTML":"<li><a href=\"http://www.massbank.jp/\">MassBank</a> - Open souce databases and tools for mass spectrometry reference spectra.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Mass Spectra</h3>","itemHTML":"<li><a href=\"https://mona.fiehnlab.ucdavis.edu/\">MoNA MassBank of North America</a> - Meta database of metabolite mass spectra, metadata and associated compounds.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Protein</h3>","itemHTML":"<li><a href=\"https://www.proteinatlas.org/\">THE HUMAN PROTEIN ATLAS</a> - One of the biggest human protein database contained cells, tissues, and organs.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Protein</h3>","itemHTML":"<li><a href=\"https://www.uniprot.org/\">UniProt</a> - The collection of functional information on proteins.</li>","updatedAt":"2022-05-15T18:34:44.000Z"},{"categoryHTML":"<h2>Databases</h2><h3>Genome</h3>","itemHTML":"<li><a href=\"https://www.ncbi.nlm.nih.gov/projects/genome/guide/human/index.shtml\">Human Genome Resources at NCBI</a> - Database 