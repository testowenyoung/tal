{"componentChunkName":"component---src-templates-awesome-timeline-js","path":"/writing-resources/awesome-scientific-writing/","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"awesomeListMeta":{"readmeParsedAt":"2022-10-14T05:10:50.000Z","repo":"writing-resources/awesome-scientific-writing","descriptionHTML":"<div><g-emoji class=\"g-emoji\" alias=\"keyboard\" fallback-src=\"https://github.githubassets.com/images/icons/emoji/unicode/2328.png\">⌨️</g-emoji> A curated list of awesome tools, demos and resources to go beyond LaTeX </div>","description":":keyboard: A curated list of awesome tools, demos and resources to go beyond LaTeX ","stargazerCount":451,"readmeItemsUpdatedTime":1659287438000,"category":"Miscellaneous"},"allAwesomeItem":{"nodes":[{"categoryHTML":"<h2>Converters and Filters</h2>","itemHTML":"<li><a href=\"https://quarto.org\">Quarto</a> - Compile R Markdown, and Jupyter Notebooks to PDFs, Slides and Websites. Supports R, Python, and Julia 🔖 🔗.</li>","updatedAt":"2022-07-31T17:10:38.000Z"},{"categoryHTML":"<h2>Tutorials</h2>","itemHTML":"<li><a href=\"https://www.ds-econ.com/write-your-whole-paper-in-r-it-is-better/\">3 frameworks into one — Write your next paper with R Studio!</a> - Article provides an overview to a workflow that combines R Markdown (bookdown), Zotero (literature management), and Notion (note taking on research papers) to write academic papers.</li>","updatedAt":"2022-07-31T17:10:38.000Z"},{"categoryHTML":"<h2>Tutorials</h2>","itemHTML":"<li><a href=\"https://www.ds-econ.com/quarto/\">Heads up! Quarto is here to stay. Immediately combine R &#x26; Python in your next document</a> - Summary of the capabilities of Quarto, why to use it, and how it compares to R Markdown. Also contains tips for M1 Mac users on how to fix a common problem with reticulate.</li>","updatedAt":"2022-07-31T17:10:38.000Z"},{"categoryHTML":"<h2>Word Processors</h2>","itemHTML":"<li><a href=\"https://github.com/marktext/marktext\">Marktext</