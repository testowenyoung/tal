esomelist-badge\" href=\"https://github.com/rstudio/bookdown-demo/#readme\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">433</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":433,\"repo\":\"rstudio/bookdown-demo\"}____TRACK_AWESOME_REPO_ITEM_END--> - Minimal\nexample of a book based on R Markdown and bookdown.</li>","updatedAt":"2020-04-07T16:27:21.000Z"},{"categoryHTML":"<h2>Templates</h2><h3>Books</h3>","itemHTML":"<li><a href=\"https://github.com/tompollard/phd_thesis_markdown#readme\">Template for writing a PhD thesis in\nMarkdown</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/tompollard/phd_thesis_markdown#readme\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">1.1k</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":1076,\"repo\":\"tompollard/phd_thesis_markdown\"}____TRACK_AWESOME_REPO_ITEM_END--> - Clean\norganization of files to provide a framework for writing a PhD thesis in\nmostly Markdown with a little bit of LaTeX, and compiled with Pandoc.</li>","updatedAt":"2020-04-07T16:27:21.000Z"},{"categoryHTML":"<h2>Tutorials</h2>","itemHTML":"<li><a href=\"https://github.com/clawpack/riemann_book/#readme\">Book on Riemann solvers</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/clawpack/riemann_book/#readme\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">199</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":199,\"repo\":\"clawpack/riemann_book\"}____TRACK_AWESOME_REPO_ITEM_END--> - This\nexample uses a custom <code>nbconvert</code> template and shows how to store your\nnotebooks with no output (for version control) while automatically executing\nthem before running <code>bookbook</code>, so that PDF and HTML versions include the\noutput.</li>","updatedAt":"2020-04-07T16:27:21.000Z"},{"categoryHTML":"<h2>Tutorials</h2>","itemHTML":"<li><a href=\"https://github.com/katrinleinweber/PhD-thesis/#readme\">Katrin Leinweber's Ph.D.\nthesis</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/katrinleinweber/PhD-thesis/#readme\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">38</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":38,\"repo\":\"katrinleinweber/PhD-thesis\"}____TRACK_AWESOME_REPO_ITEM_END--> - Automated\nwork flow involving several tools, but primarily Pandoc, <code>latexmk</code> and\nAcademic Markdown.</li>","updatedAt":"2020-04-07T16:27:21.000Z"},{"categoryHTML":"<h2>Tutorials</h2>","itemHTML":"<li><a href=\"https://github.com/jupyter4edu/jupyter-edu-book/#readme\">Teaching and learning with\nJupyter</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/jupyter4edu/jupyter-edu-book/#readme\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">382</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":382,\"repo\":\"jupyter4edu/jupyter-edu-book\"}____TRACK_AWESOME_REPO_ITEM_END--> - Book\nwritten in R Markdown, bookdown and also rendered as HTML, PDF and\nEPUB.</li>","updatedAt":"2020-04-07T16:27:21.000Z"},{"categoryHTML":"<h2>Tutorials</h2>","itemHTML":"<li><a href=\"https://www.draketo.de/english/emacs/writing-papers-in-org-mode-acpd\">Writing scientific papers for ACPD using Emacs\nOrg-mode</a> - Detailed\ntutorial on authoring a paper by seamlessly integrating with LaTeX\ncommands within Org-mode.</li>","updatedAt":"2020-04-07T16:27:21.000Z"},{"categoryHTML":"<h2>Converters and Filters</h2>","itemHTML":"<li><a href=\"https://docutils.sourceforge.io/docs/\">docutils</a> - Python package which can\nconvert reStructuredText into various formats and provides command-line\ntools to do it 🔗.</li>","updatedAt":"2020-03-21T13:18:53.000Z"},{"categoryHTML":"<h2>Converters and Filters</h2>","itemHTML":"<li><a href=\"https://cicero.xyz/\">Cicero</a> - Python package which renders HTML presentations\nfrom Markdown source using remark or reveal.js 🔗.</li>","updatedAt":"2020-03-20T18:05:14.000Z"},{"categoryHTML":"<h2>Converters and Filters</h2>","itemHTML":"<li><a href=\"https://nbconvert.readthedocs.io/en/latest/\">nbconvert</a> - Convert Jupyter\nnotebooks into <code>reveal.js</code> presentations, PDF, HTML, Markdown,\nreStructuredText and more.</li>","updatedAt":"2019-10-07T07:44:17.000Z"},{"categoryHTML":"<h2>Spell Checking and Linting</h2>","itemHTML":"<li><a href=\"https://languagetool.org/\">LanguageTool</a> - Open source grammar, style and</li>","updatedAt":"2019-10-07T07:44:17.000Z"}]},"previous":{"id":"awesomes/github.com/aliesbelik/awesome-gatling","repo":"aliesbelik/awesome-gatling"},"next":{"id":"awesomes/github.com/burningtree/awesome-json","repo":"burningtree/awesome-json"}},"pageContext":{"repo":"writing-resources/awesome-scientific-writing","id":"awesomes/github.com/writing-resources/awesome-scientific-writing","previousId":"awesomes/github.com/aliesbelik/awesome-gatling","nextId":"awesomes/github.com/burningtree/awesome-json"}},"staticQueryHashes":["228695001","2744905544","2828988102"]}