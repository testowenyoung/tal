xt":{"type":"day","from":1615334400000,"to":1615420799999,"previousId":"2021-03-11","nextId":"2021-03-09","nextName":"Mar 9th, 2021","previousName":"Mar 11th, 2021"}},"staticQueryHashes":["147714651","228695001","2744905544"]}