2:06.000Z"},{"awesomeListRepo":"nglgzz/awesome-clean-tech","categoryHTML":"<h2>Companies</h2><h3>Vegetation &#x26; Agriculture</h3>","itemHTML":"<li>\n<p><a href=\"https://www.vultus.io/\">Vultus</a> | Sweden | 2016</p>\n<p>Uses satellite imaging to save fertilizer usage up to 30%, and track crops health. This allows farmers to reduce their Nitrous Oxide emissions, a greenhouse gas that is 298 times more potent than CO2.</p>\n</li>","updatedAt":"2021-09-06T07:12:06.000Z"},{"awesomeListRepo":"nglgzz/awesome-clean-tech","categoryHTML":"<h2>More Resources</h2>","itemHTML":"<li><a href=\"https://www.norrsken.org/\">Norrsken Foundation</a> - Swedish foundation which supports and invests in organizations that have a positive impact on society.</li>","updatedAt":"2021-09-06T07:12:06.000Z"}]}},"pageContext":{"type":"day","from":1630886400000,"to":1630972799999,"previousId":"2021-09-07","nextId":"2021-09-05","nextName":"Sep 5th, 2021","previousName":"Sep 7th, 2021"}},"staticQueryHashes":["228695001","2744905544","2828988102"]}