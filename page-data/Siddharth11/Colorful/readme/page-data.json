 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">539</span></span></a> - Palettable (formerly brewer2mpl) is a library of color palettes for Python</li>\n<li><a href=\"http://picocli.info/\">picocli</a> - Small library for creating Java command line applications with ANSI colors and styles.</li>\n<li><a href=\"https://github.com/sarcadass/granim.js\">granim.js</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/sarcadass/granim.js\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">4.7k</span></span></a> - Create fluid and interactive gradient animations.</li>\n<li><a href=\"https://github.com/mistic100/tinygradient\">tinygradient</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/mistic100/tinygradient\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">140</span></span></a> - Fast and small gradients manipulation.</li>\n<li><a href=\"https://github.com/bgrins/TinyColor\">TinyColor</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/bgrins/TinyColor\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">3.8k</span></span></a> - Fast, small color manipulation and conversion for JavaScript.</li>\n<li><a href=\"https://github.com/internalfx/distinct-colors\">Distinct Colors</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/internalfx/distinct-colors\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">91</span></span></a> - Generate a palette of visually distinct colors.</li>\n<li><a href=\"https://github.com/ricokahler/color2k\">color2k</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/ricokahler/color2k\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">374</span></span></a> - A color parsing and manipulation lib.</li>\n</ul>\n<h4 id=\"web-app\" style=\"position:relative;\"><a href=\"#web-app\" aria-label=\"web app permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Web App</h4>\n<ul>\n<li><a href=\"http://tristen.ca/hcl-picker/\">Color Picker for Data</a> - Hold chroma constant and pick your palette with ease.</li>\n<li><a href=\"http://colorbrewer2.org/\">Colorbrewer2</a> - Multi-hue and single-hue palettes for heat maps and data visualization.</li>\n<li><a href=\"https://coolors.co/\">Coolors</a> - Generate infinite color palettes for your designs and share.</li>\n<li><a href=\"http://flatuicolors.com/\">Flat UI Colors</a> - UI color set.</li>\n<li><a href=\"http://www.materialui.co/\">Material Design Colors</a> -  Material Design Colors, Flat UI Colors and Material Design Icons.</li>\n<li><a href=\"http://palettab.com/\">Palettab</a> - New color palette and font inspiration with every tab (Chrome Extension).</li>\n<li><a href=\"http://paletton.com\">Paletton</a> - The Color Scheme Designer.</li>\n<li><a href=\"http://www.pictaculous.com/\">Pictaculous</a> - Generate color palette with an image.</li>\n<li><a href=\"https://color.adobe.com/\">Adobe Color Wheel</a> - Create color schemes with the color wheel.</li>\n<li><a href=\"http://elrumordelaluz.github.io/draGGradients/\">Drag Gradients</a> - Generate and customize multiple css3 radial gradients.</li>\n<li><a href=\"https://github.com/jimniels/sassme\">SassMe</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/jimniels/sassme\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">48</span></span></a> - Visualize SASS color functions in real-time without compiling.</li>\n<li><a href=\"http://jxnblk.com/shade/\">Shade</a> - Mathematically derived gradient explorer.</li>\n<li><a href=\"http://www.colourco.de/\">Colourco</a> - Easily and intuitively combine colours.</li>\n<li><a href=\"http://hslpicker.com/\">HSL Color Picker</a> - HSL Color Picker.</li>\n<li><a href=\"http://kazzkiq.github.io/svg-color-filter/\">SVG Color Filter Playground</a> - Understand how feColorMatrix works.</li>\n<li><a href=\"http://www.randoma11y.com\">Random A11y</a> - Generates a random palette that is a11y friendly.</li>\n<li><a href=\"http://savemypalette.com/\">Save My Palette</a> - Save, share, and export your color palettes.</li>\n<li><a href=\"https://color.hailpixel.com\">Colordot</a> - A color picker for humans.</li>\n<li><a href=\"http://www.materialpalette.com/\">Material Palette</a> - Material Design color palette generator.</li>\n<li><a href=\"http://www.0to255.com/\">0to255</a> - Find variations of any color.</li>\n<li><a href=\"http://147colors.com/\">147 Colors</a> - Learn CSS color names.</li>\n<li><a href=\"http://www.shutterstock.com/labs/spectrum/\">Shutterstock Spectrum</a> - Search Images by Color with Spectrum.</li>\n<li><a href=\"http://colrd.com/\">ColRD</a> - Create and share color inspiration with the world.</li>\n<li><a href=\"http://www.checkmycolours.com/\">CheckMyColours</a> - Check color combinations of all DOM elements for sufficient contrast.</li>\n<li><a href=\"http://www.dasplankton.de/ContrastA/\">Contrast-A</a> -  Inspect color combinations for acceptable contrast and displays.</li>\n<li><a href=\"http://www.palettable.io/\">Palettable</a> - Generate beautiful color palettes with no prior design knowledge.</li>\n<li><a href=\"http://vrl.cs.brown.edu/color\">Colorgorical</a> - Generate a palette with n colors.</li>\n<li><a href=\"http://colorlibrary.ch/\">Color Library</a> - Automated Color Separation.</li>\n<li><a href=\"http://colorsupplyyy.com/app/\">Color Supply</a> - Inspirational color palettes from designers &#x26; illustrators around the world.</li>\n<li><a href=\"http://www.colorfavs.com/\">ColorFavs</a> - Create and Discover Beautiful Color Palettes and Colors.</li>\n<li><a href=\"http://www.colormind.io/\">Colormind</a> - Colormind is a color scheme generator that uses deep learning.</li>\n<li><a href=\"https://icolorpalette.com\">iColorpalette</a> - Create, browse or export (aco, ase, svg, png, pdf) color palettes by color or themes.</li>\n<li><a href=\"https://geenes.app/\">geenes</a> - Create a color scale in seconds, then export it to sketch or code.</li>\n<li><a href=\"https://maketintsandshades.com/\">Tints and Shades</a> - Display tints and shades of a given hex color in 10% increments.</li>\n<li><a href=\"https://enes.in/sorted-colors/\">Sorted colors</a> - Sorted named CSS colors in a way that it shows related colors together.</li>\n<li><a href=\"https://croma.app\">Croma</a> - Generate color palettes from image and colors</li>\n</ul>\n<h2 id=\"color-palettes\" style=\"position:relative;\"><a href=\"#color-palettes\" aria-label=\"color palettes permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-