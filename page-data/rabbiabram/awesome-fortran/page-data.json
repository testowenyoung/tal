esomelist-badge\" href=\"https://github.com/szaghi/PreForM\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">23</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":23,\"repo\":\"szaghi/PreForM\"}____TRACK_AWESOME_REPO_ITEM_END--> - Preprocessor for Fortran poor Men.</li>","updatedAt":"2015-02-02T11:27:59.000Z"},{"categoryHTML":"<h2>Automatic documentation</h2>","itemHTML":"<li><a href=\"https://github.com/cmacmackin/ford\">FORD</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/cmacmackin/ford\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">27</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":27,\"repo\":\"cmacmackin/ford\"}____TRACK_AWESOME_REPO_ITEM_END--> - An automatic documentation generator for modern Fortran programs.</li>","updatedAt":"2015-02-02T11:27:59.000Z"},{"categoryHTML":"<h2>Computational Fluid Dynamics</h2>","itemHTML":"<li><a href=\"https://github.com/szaghi/OFF/tree/testing\">OFF</a> - Open source Finite volume Fluid dynamics code.</li>","updatedAt":"2015-02-02T11:27:59.000Z"},{"categoryHTML":"<h2>Fortran Websites</h2>","itemHTML":"<li><a 