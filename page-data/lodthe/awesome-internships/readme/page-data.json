{"componentChunkName":"component---src-templates-awesome-readme-js","path":"/lodthe/awesome-internships/readme","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"markdownRemark":{"id":"1deee580-9095-5c46-bec6-963e81a9756c","html":"<h1 id=\"awesome-internships-awesome\" style=\"position:relative;\"><a href=\"#awesome-internships-awesome\" aria-label=\"awesome internships awesome permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Awesome Internships <a href=\"https://awesome.re\"><img src=\"https://awesome.re/badge.svg\" alt=\"Awesome\"></a></h1>\n<blockquote>\n<p>A curated list of tech internships resources ✨</p>\n</blockquote>\n<p>The repository contains useful information for everyone who is looking for a tech internship!</p>\n<h2 id=\"contents\" style=\"position:relative;\"><a href=\"#contents\" aria-label=\"contents permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Contents</h2>\n<ul>\n<li><a href=\"#general\">General</a></li>\n<li><a href=\"#where-to-apply\">Where to apply</a></li>\n<li><a href=\"#how-to-write-cv\">How to write CV</a></li>\n<li><a href=\"#cv-examples\">CV examples</a></li>\n<li><a href=\"#cv-analyzers\">CV analyzers</a></li>\n<li><a href=\"#feedback-on-your-cv\">Feedback on your CV</a></li>\n<li><a href=\"#where-to-get-an-employee-referral\">Where to get an employee referral</a></li>\n<li><a href=\"#practice-platforms\">Practice platforms</a></li>\n<li><a href=\"#mock-interview-platforms\">Mock interview platforms</a></li>\n</ul>\n<hr>\n<h2 id=\"general\" style=\"position:relative;\"><a href=\"#general\" aria-label=\"general permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>General</h2>\n<ul>\n<li><a href=\"https://pittcs.wiki/zero-to-offer/\">Zero to Offer by the Pitt Computer Science Club</a> - A part of the course that will help you land offers from top tech companies.</li>\n</ul>\n<h2 id=\"where-to-apply\" style=\"position:relative;\"><a href=\"#where-to-apply\" aria-label=\"where to apply permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Where to apply</h2>\n<ul>\n<li><a href=\"https://github.com/pittcsc/Summer2022-Internships\">Summer 2022 Internships</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/pittcsc/Summer2022-Internships\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">14.3k</span></span></a> - A curated list of 2022 internships.</li>\n<li><a href=\"https://github.com/Pitt-CSC/NewGrad-2021\">2021 New Grad Applications</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/Pitt-CSC/NewGrad-2021\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">1.8k</span></span></a> - A curated list of 2021 new grad roles.</li>\n<li><a href=\"https://www.levels.fyi/internships/\">Relevant levels.fyi internships list</a> - A collection of intern roles with salaries.</li>\n</ul>\n<h2 id=\"how-to-write-cv\" style=\"position:relative;\"><a href=\"#how-to-write-cv\" aria-label=\"how to write cv permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>How to write CV</h2>\n<ul>\n<li><a href=\"https://www.reddit.com/r/cscareerquestions/wiki/faq_resumes\">r/cscareerquestions FAQ</a> - Tips from CS Career Questions.</li>\n<li><a href=\"https://www.notion.so/lodthe/Cracking-the-coding-interview-tips-301b9b8df5bd422aa9dbf37604afe9e9\">Cracking the coding interview tips</a> - Advice from the legendary book about interviews.</li>\n<li><a href=\"https://www.careercup.com/resume\">This Is What A GOOD Resume Should Look Like</a> - What to include in CV.</li>\n<li><a href=\"https://www.youtube.com/watch?v=BYUy1yvjHxE&#x26;feature=youtu.be\">Create Your Resume for Google: Tips and Advice</a> - A video from Google recruiters.</li>\n<li><a href=\"https://zety.com/blog/computer-science-resume\">Article on Zety</a> - How to write each section in CV.</li>\n</ul>\n<h2 id=\"cv-examples\" style=\"position:relative;\"><a href=\"#cv-examples\" aria-label=\"cv examples permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>CV examples</h2>\n<ul>\n<li><a href=\"https://ru.overleaf.com/gallery/tagged/cv\">Overleaf gallery</a> - A collection of well-structured CV. You can edit them in the OverLeaf online TeX editor.</li>\n<li><a href=\"https://resumehub.org\">Resumehub</a> - Choose a company and a role and find an appropriate template.</li>\n<li><a href=\"https://www.kickresume.com/en/help-center/software-engineering-resume-samples\">Kickresume</a> - A collection of awesome resumes with role and company description.</li>\n<li><a href=\"https://zety.com/cv-templates\">Zety CV Templates</a> - Just pick one of 18+ CV templates, fill it out, and download in seconds.</li>\n</ul>\n<h2 id=\"cv-analyzers\" style=\"position:relative;\"><a href=\"#cv-analyzers\" aria-label=\"cv analyzers permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>CV analyzers</h2>\n<ul>\n<li><a href=\"https://cvcompiler.com\">CV Compiler</a> - They synergized NLP technology and human insight to provide you with the best tech resume enhancement service available.</li>\n<li><a href=\"https://resumeworded.com\">Resume Worded</a> - An online resume grader that instantly scores your resume and gives you detailed feedback on how to get more opportunities.</li>\n<li><a href=\"https://www.vmock.com\">VMock</a> - It delivers personalized career guidance to job seekers across the world.</li>\n<li><a href=\"https://grammarly.com/\">Grammarly</a> - Find grammatical errors in your CV.</li>\n</ul>\n<h2 id=\"feedback-on-your-cv\" style=\"position:relative;\"><a href=\"#feedback-on-your-cv\" aria-label=\"feedback on your cv permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Feedback on your CV</h2>\n<ul>\n<li><a href=\"https://www.reddit.com/r/cscareerquestions\">/r/cscareerquestions</a> - A subreddit where people create advice threads to get any feedback.</li>\n<li><a href=\"https://discord.gg/6EyEDKk\">CS Career Hackers</a> - A discord channel for tech internships and jobs discussion.</li>\n<li><a href=\"https://www.topcv.com\">TopCV</a> - Get detailed feedback from experts.</li>\n</ul>\n<h2 id=\"where-to-get-an-employee-referral\" style=\"position:relative;\"><a href=\"#where-to-get-an-employee-referral\" aria-label=\"where to get an employee referral permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Where to get an employee referral</h2>\n<ul>\n<li><a href=\"https://repher.me\">Repher</a> - Create a referral request for no more than 8 companies.</li>\n<li><a href=\"https://refsy.io\">Refsy</a> - Sign up to join the engineering community as a job seeker or referrer.</li>\n</ul>\n<h2 id=\"practice-platforms\" style=\"position:relative;\"><a href=\"#practice-platforms\" aria-label=\"practice platforms permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Practice platforms</h2>\n<ul>\n<li><a href=\"https://leetcode.com\">LeetCode</a> - Practice your coding skills by solving more than 800+ questions.</li>\n<li><a href=\"https://www.hackerrank.com\">HackerRank</a> - Companies host coding challenges there.</li>\n</ul>\n<h2 id=\"mock-interview-platforms\" style=\"position:relative;\"><a href=\"#mock-interview-platforms\" aria-label=\"mock interview platforms permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Mock interview platforms</h2>\n<ul>\n<li><a href=\"https://www.pramp.com\">Pramp</a> - Practice mock interviews with friends and professionals.</li>\n</ul>","tableOfContents":"<ul>\n<li>\n<p><a href=\"#awesome-internships-awesome\">Awesome Internships <img src=\"https://awesome.re/badge.svg\" alt=\"Awesome\"></a></p>\n<ul>\n<li><a href=\"#contents\">Contents</a></li>\n<li><a href=\"#general\">General</a></li>\n<li><a href=\"#where-to-apply\">Where to apply</a></li>\n<li><a href=\"#how-to-write-cv\">How to write CV</a></li>\n<li><a href=\"#cv-examples\">CV examples</a></li>\n<li><a href=\"#cv-analyzers\">CV analyzers</a></li>\n<li><a href=\"#feedback-on-your-cv\">Feedback on your CV</a></li>\n<li><a href=\"#where-to-get-an-employee-referral\">Where to get an employee referral</a></li>\n<li><a href=\"#practice-platforms\">Practice platforms</a></li>\n<li><a href=\"#mock-interview-platforms\">Mock interview platforms</a></li>\n</ul>\n</li>\n</ul>","headings":[{"id":"awesome-internships-awesome","value":"Awesome Internships Awesome","depth":1},{"id":"contents","value":"Contents","depth":2},{"id":"general","value":"General","depth":2},{"id":"where-to-apply","value":"Where to apply","depth":2},{"id":"how-to-write-cv","value":"How to write CV","depth":2},{"id":"cv-examples","value":"CV examples","depth":2},{"id":"cv-analyzers","value":"CV analyzers","depth":2},{"id":"feedback-on-your-cv","value":"Feedback on your CV","depth":2},{"id":"where-to-get-an-employee-referral","value":"Where to get an employee referral","depth":2},{"id":"practice-platforms","value":"Practice platforms","depth":2},{"id":"mock-interview-platforms","value":"Mock interview platforms","depth":2}]},"awesomeListMeta":{"readmeParsedAt":"2022-10-14T05:03:51.148Z","repo":"lodthe/awesome-internships","description":"A curated list of tech internships resources.","readmeItemsUpdatedTime":1622722087000,"descriptionHTML":"<div>A curated list of tech internships resources.</div>","stargazerCount":218,"category":"Work"},"previous":{"id":"f572625b-9c85-57d7-82fc-08a86c317559","fields":{"repo":"joho/awesome-code-review","slug":"/joho/awesome-code-review/readme"}},"next":{"id":"55e9ec87-1e8d-5a18-a372-ea8a4b1df7e8","fields":{"repo":"sdnds-tw/awesome-sdn","slug":"/sdnds-tw/awesome-sdn/readme"}}},"pageContext":{"repo":"lodthe/awesome-internships","id":"1deee580-9095-5c46-bec6-963e81a9756c","previousId":"f572625b-9c85-57d7-82fc-08a86c317559","nextId":"55e9ec87-1e8d-5a18-a372-ea8a4b1df7e8"}},"staticQueryHashes":["228695001","2744905544","2828988102"]}