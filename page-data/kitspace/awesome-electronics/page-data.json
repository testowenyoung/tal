{"componentChunkName":"component---src-templates-awesome-timeline-js","path":"/kitspace/awesome-electronics/","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"awesomeList":{"repo":"kitspace/awesome-electronics","descriptionHTML":"<div>A curated list of awesome resources for electronic engineers and hobbyists</div>","description":"A curated list of awesome resources for electronic engineers and hobbyists","stargazerCount":3558,"repoUpdatedTime":1624481497000},"awesomeListMeta":{"readmeParsedAt":"2021-06-30T23:29:41.093Z"},"allAwesomeItem":{"nodes":[{"categoryHTML":"<h2>Learning</h2><h3>Theory and Courses</h3>","itemHTML":"<li><a href=\"https://maritime.org/doc/#neets\">NEETS (Navy Electricity and Electronics Training Series)</a> (<a href=\"https://github.com/thinkitdata/neets/tree/master/modules\">alternative link</a>)- U.S. Navy Non-Resident Training Course Material.</li>","updatedAt":"2021-06-23T20:51:37.000Z"},{"categoryHTML":"<h2>Other Lists</h2>","itemHTML":"<li><a href=\"https://github.com/kelu124/awesome-latticeFPGAs\">Awesome Lattice FPGAs</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/kelu124/awesome-latticeFPGAs\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">86</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":86,\"repo\":\"kelu124/awesome-latticeFPGAs\"}____TRACK_AWESOME_REPO_ITEM_END--> - A curated list of awesome open-source FPGA boards</li>","updatedAt":"2021-03-29T00:19:00.000Z"},{"categoryHTML":"<h2>Subscription Kit Services</h2>","itemHTML":"<li><a href=\"https://hackerboxes.com/\">HackerBoxes</a> - A monthly surprise box which includes projects, components, modules and tools.</li>","updatedAt":"2021-03-05T13:00:19.000Z"},{"categoryHTML":"<h2>Learning</h2><h3>Technical Tutorials</h3>","itemHTML":"<li><a href=\"https://www.staycaffeinated.com/2021/02/21/how-to-design-a-motherboard-for-your-project-part-1\">How to design a motherboard for your electronics project</a> - Introductory tutorial on Schematic &#x26; PCB design</li>","updatedAt":"2021-02-23T19:09:20.000Z"},{"categoryHTML":"<h2>CAD Specific</h2><h3>KiCad</h3>","itemHTML":"<li><a href=\"https://github.com/nerdyscout/kicad-exports\">kicad-exports</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/nerdyscout/kicad-exports\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">50</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":50,\"repo\":\"nerdyscout/kicad-exports\"}____TRACK_AWESOME_REPO_ITEM_END--> - Auto generate files (schematics, gerbers, BoM, plots, 3D model) for any KiCAD project. Run it locally or on every <code>git push</code> with a CI like Github Actions.</li>","updatedAt":"2020-11-30T12:34:02.000Z"},{"categoryHTML":"<h2>Blogs</h2>","itemHTML":"<li><a href=\"https://n-o-d-e.net/\">N-O-D-E</a> - Blog about DIY electronics, hardware, and technology.</li>","updatedAt":"2020-10-03T14:29:54.000Z"},{"categoryHTML":"<h2>Videos</h2>","itemHTML":"<li><a href=\"https://strangeparts.com\">Strange Parts</a> - <a href=\"https://www.youtube.com/channel/UCO8DQrSp5yEP937qNqTooOw\">YouTube channel</a> about electronics, manufacturing, making, world travel, living in and making things in China.</li>","updatedAt":"2020-07-05T11:32:15.000Z"},{"categoryHTML":"<h2>Videos</h2>","itemHTML":"<li><a href=\"http://bigclive.com\">BigClive</a> - <a href=\"https://www.youtube.com/user/bigclivedotcom\">YouTube channel</a> about teardowns (including dangerous products), circuit reverse-engineering and tutorials.</li>","updatedAt":"2020-07-05T11:30:44.000Z"},{"categoryHTML":"<h2>Simulators</h2><h3>Analog and Mixed Signal Circuit Simulators</h3>","itemHTML":"<li><a href=\"http://dd6um.darc.de/QucsStudio/qucsstudio.html\">QucsStudio</a> - Free, closed-source, Windows-only fork of Qucs with a similar interface, new engine, and more features.</li>","updatedAt":"2020-05-21T15:26:49.000Z"},{"categoryHTML":"<h2>PCB Batching Services</h2>","itemHTML":"<li><a href=\"https://pcbshopper.com/\">PCBShopper</a> - Comparison service for quite a lot of different PCB batching and assembly services.</li>","updatedAt":"2020-05-21T15:26:49.000Z"},{"categoryHTML":"<h2>Project Sharing Platforms</h2>","itemHTML":"<li><a href=\"https://kitspace.org\">Kitspace</a> - Project sharing site that helps you buy parts and re-build projects. Open source and developed by yours truly.</li>","updatedAt":"2020-05-21T15:26:49.000Z"},{"categoryHTML":"<h2>Project Sharing Platforms</h2>","itemHTML":"<li><a href=\"https://cadlab.io/\">CADLAB</a> - Another Git-based project hosting and collaboration platform for hardware development.</li>","updatedAt":"2020-05-21T15:26:49.000Z"},{"categoryHTML":"<h2>Inventory Management and Purchasing</h2>","itemHTML":"<li><a href=\"https://partsbox.io\">PartsBox</a> - Web service to manage your part inventory with a nice user interface and Octopart integration.</li>","updatedAt":"2020-05-21T15:26:49.000Z"},{"categoryHTML":"<h2>Inventory Management and Purchasing</h2>","itemHTML":"<li><a href=\"https://partkeepr.org\">PartKeepr</a> - Open source web service for managing your part inventory with parametric search and automatic datasheet import.</li>","updatedAt":"2020-05-21T15:26:49.000Z"},{"categoryHTML":"<h2>Miscellaneous Web Services</h2>","itemHTML":"<li><a href=\"https://eyrie.io\">Eyrie</a> - For viewing Eagle and KiCad designs online.</li>","updatedAt":"2020-05-21T15:26:49.000Z"},{"categoryHTML":"<h2>Miscellaneous Web Services</h2>","itemHTML":"<li><a href=\"https://www.snapeda.com\">SnapEDA</a> - Parts library with free symbols &#x26; footprints. (Compatible with Eagle, KiCad, Altium, OrCad, Allegro, etc.)</li>","updatedAt":"2020-05-21T15:26:49.000Z"},{"categoryHTML":"<h2>Podcasts</h2>","itemHTML":"<li><a href=\"https://embedded.fm/\">Embedded.fm</a> - Christopher and Elecia White discuss embedded systems development and much more, often with guests.</li>","updatedAt":"2020-05-21T15:26:49.000Z"},{"categoryHTML":"<h2>Podcasts</h2>","itemHTML":"<li><a href=\"http://thesparkgap.net\">The Spark Gap Podcast</a> - Covers a specific EE topic each episode, sometimes with guests.</li>","updatedAt":"2020-05-21T15:26:49.000Z"},{"categoryHTML":"<h2>Learning</h2><h3>Theory and Courses</h3>","itemHTML":"<li><a href=\"https://www.ibiblio.org/kuphaldt/electricCircuits/\">Lessons In Electric Circuits</a> - Free high quality textbooks and worksheets with emphasis on theory, simulation, and the socratic method.</li>","updatedAt":"2020-05-18T04:34:50.000Z"},{"categoryHTML":"<h2>Learning</h2><h3>Theory and Courses</h3>","itemHTML":"<li><a href=\"https://ultimateelectronicsbook.com/\">Ultimate Electronics: Practical Circuit Design and Analysis</a> - Free online book with interactive schematics &#x26; simulations by CircuitLab (under development).</li>","updatedAt":"2020-05-18T04:34:50.000Z"},{"categoryHTML":"<h2>Learning</h2><h3>Theory and Courses</h3>","itemHTML":"<li><a href=\"https://www.khanacademy.org/science/electrical-engineering\">Khan Academy - Electrical Engineering</a> - Non-profit learning platform with a full course on electrical engineering and related topics.</li>","updatedAt":"2020-05-18T04:34:50.000Z"},{"categoryHTML":"<h2>Simulators</h2><h3>Analog and Mixed Signal Circuit Simulators</h3>","itemHTML":"<li><a href=\"http://ngspice.sourceforge.net/\">ngspice</a> - Open source SPICE circuit simulator.</li>","updatedAt":"2020-05-18T04:34:50.000Z"},{"categoryHTML":"<h2>Simulators</h2><h3>Analog and Mixed Signal Circuit Simulators</h3>","itemHTML":"<li><a href=\"http://www.falstad.com/circuit/circuitjs.html\">Circuit JS/Falstad</a> - Free, open source online simulator with electron flow visualization (rewrite of original Java applet by Paul Falstad).</li>","updatedAt":"2020-05-18T04:34:50.000Z"},{"categoryHTML":"<h2>Simulators</h2><h3>Analog and Mixed Signal Circuit Simulators</h3>","itemHTML":"<li><a href=\"https://everycircuit.com\">EveryCircuit</a> - Free to try online, visual, interactive circuit simulator for simpler circuits.</li>","updatedAt":"2020-05-18T04:34:50.000Z"},{"categoryHTML":"<h2>Gerber Viewers</h2><h3>Installable</h3>","itemHTML":"<li><a href=\"https://kicad-pcb.org/\">KiCad GerbView</a> - The KiCad gerber viewer.</li>","updatedAt":"2020-05-18T04:34:50.000Z"},{"categoryHTML":"<h2>Free EDA Packages</h2>","itemHTML":"<li><a href=\"https://www.rs-online.com/designspark/pcb-software\">DesignSpark PCB</a> - Gratis EDA package without restrictions, sponserd by RS Components.</li>","updatedAt":"2020-05-18T04:34:50.000Z"},{"categoryHTML":"<h2>Free EDA Packages</h2>","itemHTML":"<li><a href=\"https://circuitmaker.com/\">Altium CircuitMaker</a> - Free package from the maker of the go to pro software.</li>","updatedAt":"2020-05-18T04:34:50.000Z"},{"categoryHTML":"<h2>CAD Specific</h2><h3>KiCad</h3>","itemHTML":"<li><a href=\"https://github.com/xesscorp/kicad-3rd-party-tools\">Xesscorp's list of KiCad 3rd party tools</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/xesscorp/kicad-3rd-party-tools\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-w