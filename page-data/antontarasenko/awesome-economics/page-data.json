{"componentChunkName":"component---src-templates-awesome-timeline-js","path":"/antontarasenko/awesome-economics/","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"awesomeList":{"repo":"antontarasenko/awesome-economics","descriptionHTML":"<div>A curated collection of links for economists</div>","description":"A curated collection of links for economists","stargazerCount":739,"repoUpdatedTime":1614539083000},"awesomeListMeta":{"readmeParsedAt":"2021-06-30T23:34:38.015Z"},"allAwesomeItem":{"nodes":[{"categoryHTML":"<h2>Discussions</h2>","itemHTML":"<li>Discord - A popular chat platform\n<ul>\n<li><a href=\"https://discord.gg/n9V7hjNtPV\">Academic Economics</a> - A community with rooms to discuss economics and help members with exercises</li>\n</ul>\n</li>","updatedAt":"2021-02-28T19:04:43.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Economists</h3>","itemHTML":"<li><a href=\"https://github.com/mwt\">mwt</a> - Northwestern University, USA</li>","updatedAt":"2021-02-22T12:18:06.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Data</h3>","itemHTML":"<li><a href=\"https://sites.google.com/site/medevecon/devecondata\">MEDevEcon</a> - Data related to development economics.</li>","updatedAt":"2020-11-04T17:17:38.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/gboehl/econsieve\">econsieve</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/gboehl/econsieve\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">6</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":6,\"repo\":\"gboehl/econsieve\"}____TRACK_AWESOME_REPO_ITEM_END--> - Filter for large-scale nonlinear models.</li>","updatedAt":"2020-03-11T12:09:19.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/gboehl/macro_puzzles\">macro_puzzles</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/gboehl/macro_puzzles\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">38</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":38,\"repo\":\"gboehl/macro_puzzles\"}____TRACK_AWESOME_REPO_ITEM_END--> - A list of puzzles in macroeconomics.</li>","updatedAt":"2020-03-11T12:09:19.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/gboehl/pydsge\">pydsge</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/gboehl/pydsge\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">22</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":22,\"repo\":\"gboehl/pydsge\"}____TRACK_AWESOME_REPO_ITEM_END--> - Tools to solve, filter, and estimate DSGE models with occasionally binding constraints.</li>","updatedAt":"2020-03-11T12:09:19.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Economists</h3>","itemHTML":"<li><a href=\"https://github.com/gboehl\">gboehl</a> - Goethe University Frankfurt, Frankfurt Germany.</li>","updatedAt":"2018-10-31T15:18:39.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Economists</h3>","itemHTML":"<li><a href=\"https://github.com/nealbob\">nealbob</a> - Australian National University, Canberra, Australia.</li>","updatedAt":"2018-10-31T15:18:39.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/EconForge\">EconForge</a> - Team around Pablo Winant providing packages to solve economic models.</li>","updatedAt":"2018-10-31T15:18:39.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/rsvp/fecon235\">fecon235</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/rsvp/fecon235\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">717</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":717,\"repo\":\"rsvp/fecon235\"}____TRACK_AWESOME_REPO_ITEM_END--> - Computational tools for financial economics, Python code base and tutorials using Jupyter notebooks, includes data retrieval, graphics, and optimization.</li>","updatedAt":"2018-10-31T15:18:39.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/davidrpugh/zice-2014\">zice-2014</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/davidrpugh/zice-2014\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">21</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":21,\"repo\":\"davidrpugh/zice-2014\"}____TRACK_AWESOME_REPO_ITEM_END--> - Course materials for Zurich Initiative for Computational Economics (ZICE) 2014.</li>","updatedAt":"2018-10-31T15:18:39.000Z"},{"categoryHTML":"<h2>Links Sent by Readers</h2>","itemHTML":"<li><a href=\"http://economics-games.com/\">Economics Games</a> - Free online classroom games for teaching economics.</li>","updatedAt":"2018-10-31T15:18:39.000Z"},{"categoryHTML":"<h2>Links Sent by Readers</h2>","itemHTML":"<li><a href=\"https://www.intelligenteconomist.com/top-economics-blogs-2016/\">Top 100 Economics Blogs</a> - Links to popular economics blogs, with brief descriptions.</li>","updatedAt":"2018-10-31T15:18:39.000Z"},{"categoryHTML":"<h2>Studying</h2><h3>Courses</h3>","itemHTML":"<li><a href=\"http://ocw.mit.edu/courses/economics/\">MIT OCW Economics</a> - Over 100 courses covering all major fields of economics. Courses include prerequisites, recommended textbooks, lecture slides, and assignments. Undergraduate and graduate programs.</li>","updatedAt":"2017-11-09T18:28:40.000Z"},{"categoryHTML":"<h2>Links Sent by Readers</h2>","itemHTML":"<li><a href=\"https://lectures.quantecon.org/py/index.html\">Quantitative Economics</a> - Lecture series by Thomas J. Sargent and John Stachurski using Python computational tools.</li>","updatedAt":"2017-08-04T08:19:45.000Z"},{"categoryHTML":"<h2>Links Sent by Readers</h2>","itemHTML":"<li><a href=\"http://devecondata.blogspot.com/\">Deveconodata Blogspot</a> - Development economics datasets. Updated regularly.</li>","updatedAt":"2017-07-31T10:20:40.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Economists</h3>","itemHTML":"<li><a href=\"https://github.com/davidrpugh\">davidrpugh</a> - Institute for New Economic Thinking, Oxford Martin School; Oxford Mathematical Institute, Oxford, UK.</li>","updatedAt":"2016-04-26T08:47:06.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Economists</h3>","itemHTML":"<li><a href=\"https://github.com/hmgaudecker\">hmgaudecker</a> - Universität Bonn, Bonn, Germany.</li>","updatedAt":"2016-04-26T08:47:06.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Economists</h3>","itemHTML":"<li><a href=\"https://github.com/jstac\">jstac</a> - Australian National University, Canberra, Australia.</li>","updatedAt":"2016-04-26T08:47:06.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Economists</h3>","itemHTML":"<li><a href=\"https://github.com/nathanlane\">nathanlane</a> - Institute for International Economic Studies, Stockholm, Sweden.</li>","updatedAt":"2016-04-26T08:47:06.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Economists</h3>","itemHTML":"<li><a href=\"https://github.com/trickvi\">trickvi</a> - Hagstofa Íslands, Iceland.</li>","updatedAt":"2016-04-26T08:47:06.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/philschatz/economics-book\">economics-book</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/philschatz/economics-book\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">24</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":24,\"repo\":\"philschatz/economics-book\"}____TRACK_AWESOME_REPO_ITEM_END--> - Economics Textbook (Openstax).</li>","updatedAt":"2016-04-26T08:47:06.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/davidrpugh/pyeconomics\">pyeconomics</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/davidrpugh/pyeconomics\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">148</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":148,\"repo\":\"davidrpugh/pyeconomics\"}____TRACK_AWESOME_REPO_ITEM_END--> - Computational economics in Python.</li>","updatedAt":"2016-04-26T08:47:06.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/QuantEcon/\">QuantEcon</a> - A library for quantitative economics.</li>","updatedAt":"2016-04-26T08:47:06.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/vfitoolkit\">VFI Toolkit</a> - Matlab toolkit for Value Function Iteration on GPU.</li>","updatedAt":"2016-04-26T08:47:06.000Z"},{"categoryHTML":"<h2>Studying</h2><h3>Useful Materials</h3>","itemHTML":"<li><a href=\"http://rfe.org/\">AEA Resources for Economists</a> - A list of useful links maintained by the American Economic Association.</li>","updatedAt":"2016-04-13T16:09:19.000Z"},{"categoryHTML":"<h2>Discussions</h2>","itemHTML":"<li><a href=\"https://www.aeaweb.org/rfe/showCat.php?cat_id=96\">AEA Blog Directory</a> - The list of major economic blogs.</li>","updatedAt":"2016-04-13T16:09:19.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Software</h3>","itemHTML":"<li><a href=\"https://git-scm.com/downloads\">Git</a> - A version control system. Useful if you want to revert changes done months ago or collaborate with other authors. DropBox also has version control, but Git is more explicit. A <a href=\"http://rogerdudler.github.io/git-guide/\">short intro</a>. Or use <a href=\"https://desktop.github.com/\">GitHub Desktop</a> if you like it simple.</li>","updatedAt":"2016-04-07T15:34:21.000Z"},{"categoryHTML":"<h2>Studying</h2><h3>Useful Materials</h3>","itemHTML":"<li><a href=\"https://cse.google.com/cse/publicurl?cx=002720237717066476899:e55ib8o11ka\">Academic Search</a> - Search across <code>.edu</code> and other educational domains. These materials are more reliable than the big Internet.</li>","updatedAt":"2016-04-04T16:45:16.000Z"},{"categoryHTML":"<h2>Studying</h2><h3>Useful Materials</h3>","itemHTML":"<li><a href=\"http://www.igmchicago.org/igm-economic-experts-panel\">IGM Economic Experts Panel</a> - Top economists reflect on policy-related issues. Some answers contain useful details.</li>","updatedAt":"2016-04-04T16:45:16.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Articles and Working Papers</h3>","itemHTML":"<li><a href=\"https://ideas.repec.org/\">IDEAS RePEc</a> - The largest database of economics publications (2,000,000 items). Searching through papers is easier with Google: <code>site:ideas.repec.org &#x3C;search term></code>. Index sources mentioned below.</li>","updatedAt":"2016-04-04T16:45:16.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Articles and Working Papers</h3>","itemHTML":"<li><a href=\"http://nber.org/papers.html\">NBER</a> - Working papers by major researchers. Many of these papers get published in peer-reviewed journal.</li>","updatedAt":"2016-04-04T16:45:16.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Articles and Working Papers</h3>","itemHTML":"<li><a href=\"http://scholar.google.com/\">Google Scholar</a> - Searching academic literature in general. Features author pages and citation counters. If you look for economic writings only, IDEAS would be more powerful.</li>","updatedAt":"2016-04-04T16:45:16.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Data</h3>","itemHTML":"<li><a href=\"http://www.imf.org/en/Data\">IMF Data</a> - The standard reference for macro data.</li>","updatedAt":"2016-04-04T16:45:16.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Data</h3>","itemHTML":"<li><a href=\"https://sites.google.com/site/davesmant/various/data-sets-sources\">Monetary Economics: Data Sources</a> - Overview of macro data sources.</li>","updatedAt":"2016-04-04T16:45:16.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Data</h3>","itemHTML":"<li><a href=\"http://www.offstats.auckland.ac.nz/\">OFFSTATS</a> - Links to official data sources by country and subject.</li>","updatedAt":"2016-04-04T16:45:16.000Z"},{"categoryHTML":"<h2>Career</h2><h3>Graduate</h3>","itemHTML":"<li><a href=\"https://www.aeaweb.org/gradstudents/index.php\">American Economic Association: Graduate Training in Economics</a> - Overview of the programs, requirements, and advices to those considering a PhD program in economics.</li>","updatedAt":"2016-04-04T16:45:16.000Z"},{"categoryHTML":"<h2>Career</h2><h3>Faculty</h3>","itemHTML":"<li><a href=\"https://www.aeaweb.org/joe/\">Job Openings for Economists</a> - The job board by the American Economic Association.</li>","updatedAt":"2016-04-04T16:45:16.000Z"},{"categoryHTML":"<h2>Studying</h2><h3>Courses</h3>","itemHTML":"<li><a href=\"https://www.edx.org/course/subject/economics-finance\">edX Economics</a> - Introductory topics, few prerequisites.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Studying</h2><h3>Courses</h3>","itemHTML":"<li><a href=\"https://www.khanacademy.org/economics-finance-domain\">Khan Academy: Economics</a> - Elementary topics.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Studying</h2><h3>Useful Materials</h3>","itemHTML":"<li><a href=\"http://economics.stackexchange.com/questions/35/what-are-the-foundational-equations-of-economics\">Foundational Equations of Economics</a> - These equations show principles behind \"thinking like an economist\". Graduate textbooks put these equiations in context.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Portals</h3>","itemHTML":"<li><a href=\"http://repec.org/\">RePEc</a> - Web services for economic researchers: bibliography, blog aggregator, new working papers, software.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Portals</h3>","itemHTML":"<li><a href=\"https://research.stlouisfed.org/resources.html\">Federal Reserve Bank of St. Louis: Web Services</a> - A list of helpful services.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Articles and Working Papers</h3>","itemHTML":"<li><a href=\"http://ssrn.com/en/index.cfm/ern/\">SSRN Economics</a> - Working papers, no journal publications.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Data</h3>","itemHTML":"<li><a href=\"https://research.stlouisfed.org/fred2/\">FRED2</a> - 380,000 (macro) time series from 80 sources. Supports plugins for importing data into Excel, Stata, R, and others. Has a mobile app.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Data</h3>","itemHTML":"<li><a href=\"http://data.worldbank.org/\">World Bank Data</a> - International macro time series. Has data import plugins.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Data</h3>","itemHTML":"<li><a href=\"https://www.quandl.com/\">Quandl</a> - Aggregate financial and economic data from multiple sources. Some data vendors sell their data via this service. Good integration with statistical software.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Software</h3>","itemHTML":"<li><a href=\"https://www.latex-project.org/\">LaTeX</a> - Economists write in LaTeX because it handles mathematics and references better than Word or LibreOffice. If you write regularly, LaTeX is worth learning.\n<ul>\n<li><a href=\"https://www.ctan.org/pkg/beamer?lang=en\">Beamer</a> - A LaTeX class for presentations.</li>\n<li><a href=\"http://www.texample.net/tikz/examples/\">TikZ</a> - An extension for drawing graphs. A <a href=\"http://cremeronline.com/LaTeX/minimaltikz.pdf\">how-to</a> and a <a href=\"http://www.texample.net/media/pgf/builds/pgfmanualCVS2012-11-04.pdf\">manual</a>.</li>\n</ul>\n</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Software</h3>","itemHTML":"<li><a href=\"http://www.lyx.org/\">LyX</a> - A free and simple editor for LaTeX.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Software</h3>","itemHTML":"<li><a href=\"https://www.zotero.org/\">Zotero</a> - Bibliography management. Also install (a) Zotero browser plugin to import papers from RePEc to your library; (b) Zotero-LyX plugin to cite literature easily.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Useful Materials</h3>","itemHTML":"<li><a href=\"http://stats.stackexchange.com/questions/2910/how-to-efficiently-manage-a-statistical-analysis-project\">How to efficiently manage a statistical analysis project?</a></li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Research</h2><h3>Useful Materials</h3>","itemHTML":"<li>RePEc Rankings by citations\n<ul>\n<li><a href=\"https://ideas.repec.org/top/top.person.all.html\">Top Authors</a></li>\n<li><a href=\"https://ideas.repec.org/top/top.inst.nbcites.html\">Economic Institutions</a></li>\n<li><a href=\"https://ideas.repec.org/top/top.item.nbcites.html\">Research Items</a></li>\n<li><a href=\"http://logec.repec.org/scripts/itemstat.pf?type=redif-software\">Software Items</a></li>\n</ul>\n</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Discussions</h2>","itemHTML":"<li>Blogs - The most popular form of self-expression among economists. The major blog aggregators:\n<ul>\n<li><a href=\"http://econacademics.org/\">EconAcademics.org</a></li>\n<li><a href=\"http://economistsview.typepad.com/\">Economist's View</a> - Mark Thoma</li>\n<li><a href=\"http://delong.typepad.com/\">Grasping Reality</a> - Brad DeLong</li>\n<li><a href=\"http://marginalrevolution.com/\">Marginal Revolution</a> - Tyler Cowen and Alex Tabarrok</li>\n<li><a href=\"http://www.voxeu.org/\">VOX CEPR</a> - Members of CEPR</li>\n</ul>\n</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Discussions</h2>","itemHTML":"<li><a href=\"https://cse.google.com/cse/publicurl?cx=002720237717066476899:i_zfef5fawa\">Economics Blog Search</a> - A Google-based search service for aforementioned blogs.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Discussions</h2>","itemHTML":"<li><a href=\"http://economics.stackexchange.com/\">StackExchange Economics</a> - A Q&#x26;A website where you can ask and answer questions.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Discussions</h2>","itemHTML":"<li>Reddit - A popular news aggregator. Has many economics-related sections, for example:\n<ul>\n<li><a href=\"https://www.reddit.com/r/GoodEconomics/\">/r/GoodEconomics/</a> - Selected pieces on economic issues.</li>\n<li><a href=\"https://www.reddit.com/r/EconPapers/\">/r/EconPapers/</a> - Discussing economic papers.</li>\n</ul>\n</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Career</h2><h3>Undergraduate</h3>","itemHTML":"<li>University rankings - May help in choosing a college.\n<ul>\n<li><a href=\"http://www.topuniversities.com/university-rankings/university-subject-rankings/2016/economics-econometrics#sorting=rank+region=+country=+faculty=+stars=false+search=\">QS World University Rankings by Subject 2016 - Economics &#x26; Econometrics</a></li>\n<li><a href=\"http://www.shanghairanking.com/SubjectEcoBus2015.html\">Academic Ranking of World Universities in Economics / Business</a></li>\n</ul>\n</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Career</h2><h3>Faculty</h3>","itemHTML":"<li><a href=\"https://econjobmarket.org/postings.php\">Econ Jobs Postings</a> - List of academic job openings.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Career</h2><h3>Faculty</h3>","itemHTML":"<li><a href=\"http://www.econjobrumors.com/wiki.php\">Economics Job Market Rumors</a> - List of job openings for economists. Informal.</li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Economists</h3>","itemHTML":"<li><a href=\"https://github.com/jesusfv\">jesusfv</a></li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Economists</h3>","itemHTML":"<li><a href=\"https://github.com/robertdkirkby\">robertdkirkby</a></li>","updatedAt":"2016-03-31T21:08:55.000Z"},{"categoryHTML":"<h2>Economics on GitHub</h2><h3>Projects</h3>","itemHTML":"<li><a href=\"https://github.com/jstac/quantecon_nyu_2016\">quantecon_nyu_2016</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/jstac/quantecon_nyu_2016\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">93</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":93,\"repo\":\"jstac/quantecon_nyu_2016\"}____TRACK_AWESOME_REPO_ITEM_END--> - Topics in Computational Economics</li>","updatedAt":"2016-03-31T21:08:55.000Z"}]},"previous":{"id":"awesomes/github.com/egeerardyn/awesome-LaTeX","repo":"egeerardyn/awesome-LaTeX"},"next":{"id":"awesomes/github.com/sublimino/awesome-funny-markov","repo":"sublimino/awesome-funny-markov"}},"pageContext":{"repo":"antontarasenko/awesome-economics","id":"awesomes/github.com/antontarasenko/awesome-economics","previousId":"awesomes/github.com/egeerardyn/awesome-LaTeX","nextId":"awesomes/github.com/sublimino/awesome-funny-markov"}},"staticQueryHashes":["228695001","2744905544","4035379035"]}