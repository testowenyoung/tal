{"componentChunkName":"component---src-templates-awesome-readme-js","path":"/johnjago/awesome-uncopyright/readme/","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"markdownRemark":{"id":"53433c0b-84ba-594e-b132-5924fdf61b9f","html":"<h1 id=\"awesome-uncopyright-awesome\" style=\"position:relative;\"><a href=\"#awesome-uncopyright-awesome\" aria-label=\"awesome uncopyright awesome permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Awesome Uncopyright <a href=\"https://github.com/sindresorhus/awesome\"><img src=\"https://cdn.rawgit.com/sindresorhus/awesome/d7305f38d29fed78fa85652e3a63e154dd8e8829/media/badge.svg\" alt=\"Awesome\"></a></h1>\n<p><a href=\"http://questioncopyright.org/\"><img src=\"https://upload.wikimedia.org/wikipedia/commons/6/62/PD-icon.svg\" alt=\"No copyright symbol\" align=\"right\" width=\"155\"></a></p>\n<p>A curated list of works in the public domain.</p>\n<p>Works in the public domain have no copyright restrictions. This can be the result of intellectual property rights expiring or being forfeited. In the case of the latter, authors have used the term <em>uncopyright</em> to describe their act of relinquishing copyright.</p>\n<h2 id=\"contents\" style=\"position:relative;\"><a href=\"#contents\" aria-label=\"contents permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Contents</h2>\n<ul>\n<li><a href=\"#art\">Art</a></li>\n<li><a href=\"#articles\">Articles</a></li>\n<li><a href=\"#blogs\">Blogs</a></li>\n<li><a href=\"#books\">Books</a></li>\n<li><a href=\"#essays\">Essays</a></li>\n<li><a href=\"#images\">Images</a></li>\n<li><a href=\"#licenses\">Licenses</a></li>\n<li><a href=\"#organizations\">Organizations</a></li>\n<li><a href=\"#related\">Related</a></li>\n<li><a href=\"#resources\">Resources</a></li>\n<li><a href=\"#software\">Software</a></li>\n<li><a href=\"#talks\">Talks</a></li>\n<li><a href=\"#license\">License</a></li>\n</ul>\n<h2 id=\"art\" style=\"position:relative;\"><a href=\"#art\" aria-label=\"art permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Art</h2>\n<ul>\n<li><a href=\"http://www.newpalmyra.org/\">#NEWPALMYRA</a> - Reconstruction of the ancient Palmyra city in virtual space.</li>\n<li><a href=\"https://www.blendswap.com/blends/search?keywords=+&#x26;is_fan_art=1&#x26;blend_license=CC-0&#x26;render_engine=&#x26;sort=downloads&#x26;direction=desc\">BlendSwap: CC0 search</a> - Quality CC0 3D models (not only) for Blender.</li>\n<li><a href=\"http://www.davidreedsmith.com/UncopyrightNotice.htm\">David Reed Smith</a> - Making tatting shuttles and drop spindles, and occasionally writing articles for fun.</li>\n<li><a href=\"http://designercandies.net/uncopyright/\">DesignerCandies</a> - High quality graphic design resources for use in design projects.</li>\n<li><a href=\"http://dotcolon.net/\">dotcolon</a> - CC0 fonts.</li>\n<li><a href=\"https://everyshirtispolitical.com/\">Every Shirt Is Political</a> - Shirts that are ethically made, hand-printed, and pay what you can priced.</li>\n<li><a href=\"http://freemusicarchive.org/search/?adv=1&#x26;quicksearch=&#x26;search-genre=Genres&#x26;duration_from=&#x26;duration_to=&#x26;music-filter-public-domain=1\">FreeMusicArchive: CC0 search</a> - Many CC0 songs.</li>\n<li><a href=\"https://freesound.org/search/?g=1&#x26;q=&#x26;f=%20license:%22Creative+Commons+0%22\">Freesound: CC0 search</a> - Thousands of CC0 sound effects and recordings.</li>\n<li><a href=\"http://www.gwennseemel.com/index.php/copyright/\">Gwenn Seemel</a> - French-American artist, painter, portraitist.</li>\n<li><a href=\"https://hdrihaven.com/\">HDRI Haven</a> - High-resolution HDR panoramas under CC0.</li>\n<li><a href=\"https://www.kenney.nl/assets\">Kenney</a> - High-quality game art under CC0.</li>\n<li><a href=\"http://michaelbeil.com/uncopyright\">Michael Beil</a> - Supporting the web. Developing. Playing music.</li>\n<li><a href=\"https://libreshot.com/\">Martin Vorel</a> - Photographer releasing his very high quality photos under CC0.</li>\n<li><a href=\"https://opengameart.org/art-search-advanced?keys=&#x26;title=&#x26;field_art_tags_tid_op=or&#x26;field_art_tags_tid=&#x26;name=&#x26;field_art_type_tid%5B%5D=9&#x26;field_art_type_tid%5B%5D=10&#x26;field_art_type_tid%5B%5D=7273&#x26;field_art_type_tid%5B%5D=14&#x26;field_art_type_tid%5B%5D=12&#x26;field_art_type_tid%5B%5D=13&#x26;field_art_type_tid%5B%5D=11&#x26;field_art_licenses_tid%5B%5D=4&#x26;sort_by=count&#x26;sort_order=DESC&#x26;items_per_page=24&#x26;Collection=\">Opengameart: CC0 search</a> - Huge number of CC0 game art.</li>\n<li><a href=\"http://publicdomainflix.com/index.html\">PublicDomainFlix</a> - Watch public domain movies online.</li>\n<li><a href=\"http://rkhive.com/legal.html\">RKHive</a> - CC0 sound fonts for music synthesis and MIDI playback.</li>\n<li><a href=\"https://www.samuelkillermann.com/\">Samuel Killermann</a> - Multi-disciplinary artist who puts his gifts to work to achieve global justice.</li>\n</ul>\n<h2 id=\"articles\" style=\"position:relative;\"><a href=\"#articles\" aria-label=\"articles permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Articles</h2>\n<ul>\n<li><a href=\"https://cr.yp.to/publicdomain.html\">Placing Documents into the Public Domain</a> - Legal details of this process.</li>\n<li><a href=\"https://en.wikipedia.org/wiki/Opposition_to_copyright\">Opposition to Copyright</a> - Wikipedia article discussing opposition to copyright.</li>\n<li><a href=\"https://creativecommons.org/2011/04/15/using-cc0-for-public-domain-software/\">Using CC0 for Public Domain Software</a> - Drawbacks of using CC0 to license computer programs.</li>\n<li><a href=\"https://alexcabal.com/why-i-release-things-into-the-public-domain\">Why I Release Things into the Public Domain</a> - Brief history of copyright law and how it has evolved to harm society instead of help it.</li>\n</ul>\n<h2 id=\"blogs\" style=\"position:relative;\"><a href=\"#blogs\" aria-label=\"blogs permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Blogs</h2>\n<ul>\n<li><a href=\"http://ariherzog.com/\">ARIHERZOG</a> - Posts on digital and political topics, as well as minimalism.</li>\n<li><a href=\"http://awesci.com/uncopyright/\">Awesci</a> - Entertaining articles mixed with scientific information.</li>\n<li><a href=\"http://www.billyshih.com/uncopyright/\">Billy Shih</a> - Blog of a web developer at Full Circle.</li>\n<li><a href=\"http://charb.it/uncopyright/\">Char Bit</a> - Writings about JavaScript from a full stack developer with 20 years of experience.</li>\n<li><a href=\"http://eclipsophile.com/\">Eclipsophile</a> - All about solar eclipses.</li>\n<li><a href=\"http://www.expandbeyondyourself.com/uncopyright/\">ExpandBeyondYourself</a> - How to transform your life via personal growth and progress.</li>\n<li><a href=\"http://www.fibrohaven.com/uncopyright/\">FibroHaven</a> - Creating a community of compassion, understanding, and healing for those with chronic illness.</li>\n<li><a href=\"http://go-beyond.org/\">Go Beyond</a> - Blog without a tagline.</li>\n<li><a href=\"http://www.gr0wing.com/uncopyright/\">gr0wing.com</a> - Personal and global change.</li>\n<li><a href=\"http://healthyenough.net/\">Healthy Enough</a> - Helping you become as fit and healthy as possible.</li>\n<li><a href=\"http://www.hobodrifter.com/uncopyright/\">HoboDrifter</a> - Posts from a former world traveler.</li>\n<li><a href=\"http://www.howtobekind.info/uncopyright/\">How To Be Kind</a> - Kind words for a kinder world.</li>\n<li><a href=\"http://jaytarlecki.com/uncopyright/attribution/\">Jay Tarlecki</a> - Personal website of Jay Tarlecki.</li>\n<li><a href=\"http://www.melissamiko.com/uncopyright/\">Melissa Miko</a> - American writer, thinker, and entrepreneur.</li>\n<li><a href=\"http://mnmlist.com/uncopyright/\">mnmlist</a> - Less is the answer.</li>\n<li><a href=\"http://publicdomainreview.org\">Public Domain Review</a> - Professional quality reviews of works in the public domain.</li>\n<li><a href=\"http://www.stafforini.com/tango/uncopyright/\">Puro compás</a> - Tango music and dancing.</li>\n<li><a href=\"http://refereemindset.com/uncopyright\">Referee Mindset</a> - Helping referees develop skills to be the best they can be.</li>\n<li><a href=\"https://boren.blog/uncopyright/\">Ryan Boren</a> - Lead developer of WordPress at Automattic.</li>\n<li><a href=\"https://dugmugg.wordpress.com/uncopyright/\">Serendipity Journal</a> - Journal of experiences with growth and faith from a Christian perspective.</li>\n<li><a href=\"https://simpletechtutorials.blogspot.com/p/uncopyright.html\">Simple Tech Tutorials</a> - Computer tutorials with a focus on simplicity.</li>\n<li><a href=\"http://www.stevepavlina.com/uncopyright-notice/\">Steve Pavlina</a> - How we can deliberately invite, process, and integrate new experiences.</li>\n<li><a href=\"https://zenhabits.net/uncopyright/\">Zen Habits</a> - Finding simplicity and mindfulness in the daily chaos of our lives.</li>\n</ul>\n<h2 id=\"books\" style=\"position:relative;\"><a href=\"#books\" aria-label=\"books permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Books</h2>\n<ul>\n<li><a href=\"http://comicbookplus.com/\">comicbookplus</a> - Read old PD comics online.</li>\n<li><a href=\"http://costoffreedom.cc/\">Cost of Freedom</a> - On the dream for a free culture.</li>\n<li><a href=\"https://librivox.org/\">LibriVox</a> - Audiobooks read by volunteers.</li>\n<li><a href=\"https://www.gutenberg.org/\">Project Gutenberg</a> - Thousands of ebooks mostly in the public domain, in a variety of formats.</li>\n<li><a href=\"https://standardebooks.org/\">Standard Ebooks</a> - Hundreds of classics, beautifully formatted and typeset.</li>\n<li><a href=\"https://en.wikisource.org/w/index.php?search=incategory%3A%22cc-zero%7CPD-old%7CPD-old-70-1923%E2%80%8E%22&#x26;title=Special%3ASearch&#x26;profile=advanced&#x26;fulltext=1&#x26;advancedSearch-current=%7B%22namespaces%22%3A%5B100%2C102%2C106%2C114%2C0%5D%7D&#x26;ns100=1&#x26;ns102=1&#x26;ns106=1&#x26;ns114=1&#x26;ns0=1\">Wikisource: PD search</a> - Thousands of PD books and texts.</li>\n</ul>\n<h2 id=\"essays\" style=\"position:relative;\"><a href=\"#essays\" aria-label=\"essays permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Essays</h2>\n<ul>\n<li><a href=\"http://www.culturelink.org/news/members/2005/members2005-011.html\">Abandoning Copyright: A Blessing for Artists, Art, and Society</a> - Discussion of how concentration of power is undesirable in every industry but particularly detrimental in the cultural field.</li>\n<li><a href=\"https://questioncopyright.org/promise\">The Surprising History of Copyright and The Promise of a Post-Copyright World</a></li>\n<li><a href=\"https://stpeter.im/writings/essays/publicdomain.html\">Who's Afraid of the Public Domain?</a> - Breaking down five common assumptions about creative individuals.</li>\n</ul>\n<h2 id=\"images\" style=\"position:relative;\"><a href=\"#images\" aria-label=\"images permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Images</h2>\n<ul>\n<li><a href=\"http://www.copyrightfreephotos.com/\">CopyrightFreePhotos.com</a> - Galleries of photos, each with their own theme.</li>\n<li><a href=\"https://www.foodiesfeed.com/license/\">Foodiesfeed</a> - A place to upload and find images of food without any copyright restriction.</li>\n<li><a href=\"https://archive.org/search.php?query=possible-copyright-status%3A%28NOT_IN_COPYRIGHT%29%20OR%20licenseurl%3A%28%22http%3A%2F%2Fcreativecommons.org%2Fpublicdomain%2Fmark%2F1.0%2F%22%29%20OR%20licenseurl%3A%28%22https%3A%2F%2Fcreativecommons.org%2Fpublicdomain%2Fzero%2F1.0%2F%22%29\">Internet Archive: PD search</a> - A huge amount of PD works.</li>\n<li><a href=\"http://librestock.com/\">LibreStock</a> - Search all public domain stock photo websites at once.</li>\n<li><a href=\"https://mystock.themeisle.com/license/\">MyStockPhotos</a> - A collection of images dedicated to the public domain through CC0.</li>\n<li><a href=\"https://negativespace.co/license/\">NegativeSpace</a> - A repository of CC0 images.</li>\n<li><a href=\"https://openclipart.org/share\">Openclipart</a> - High quality, easy to use clip art.</li>\n<li>Old images on <a href=\"https://web.archive.org/web/20190108204845/https://pixabay.com/en/service/terms/\">Pixabay</a> - <strong>New images on Pixabay are <a href=\"https://opengameart.org/forumtopic/warning-pixabay-has-changed-the-license-not-compatible-with-cc-or-gpl-anymore\">not in the public domain</a></strong>, as they are released under the <a href=\"https://pixabay.com/service/license/\">Pixabay License</a> (among other things, <a href=\"https://make.wordpress.org/themes/2019/01/13/pixabay-images-are-not-allowed/\">incompatible with the GPL</a>). Pixabay switched to the new license <a href=\"https://pixabay.com/forum/official-pixabay-news-2/the-pixabay-license-7823/\">in 2019</a>. Prior to that change, Pixabay used the <a href=\"https://web.archive.org/web/20190108204845/https://pixabay.com/en/service/terms/\">CC0 waiver</a>. Therefore, old images are <a href=\"https://pixabay.com/it/forum/official-pixabay-news-2/the-pixabay-license-7823/?pagi=4\">still in the public domain</a>, despite being <a href=\"https://pixabay.com/it/forum/official-pixabay-news-2/the-pixabay-license-7823/?pagi=4\">misleadingly tagged</a> with the Pixabay License. Before using an image, check what the state of the <a href=\"https://pixabay.com/service/\">terms of service</a> was at that point in time.</li>\n<li><a href=\"https://publicicons.lllllllllllllllll.com/\">Public Icons</a> - Collection of free icons.</li>\n<li><a href=\"https://pxhere.com/it/license\">PxHere</a> - To find and upload CC0 images.</li>\n<li><a href=\"https://www.rijksmuseum.nl/en/rijksstudio\">Rijksstudio</a> - Rijksmuseum digitised and made available public domain works from several artists including Rembrandt, Vermeer, and others.</li>\n<li><a href=\"https://skitterphoto.com/license\">Skitterphoto</a> - A place to upload and find CC0 images.</li>\n<li><a href=\"https://www.spacex.com/media\">SpaceX media</a> - SpaceX media <strong>no longer</strong> lists its images as being in the public domain. Even on <a href=\"https://web.archive.org/web/20170412063800/https://www.flickr.com/photos/spacex/16787988882/\">Flickr</a>, it uses a CC-BY-NC license. However, old images (from <a href=\"http://web.archive.org/web/20150328140645/http://www.spacex.com/media\">here</a> to <a href=\"http://web.archive.org/web/20191122175115/https://www.spacex.com/media\">here</a>) had indeed been placed into the public domain and have no copyright restriction (including some images on <a href=\"https://web.archive.org/web/20170412063800/https://www.flickr.com/photos/spacex/16787988882/\">Flickr</a>).</li>\n<li><a href=\"https://stocksnap.io/license\">StockSnap</a> - Stock photography without any copyright restrictions.</li>\n<li>Old images on <a href=\"https://unsplash.com/\">Unsplash</a>. Unsplash <strong>no longer</strong> uses CC0, so new images are not in the public domain (but all images released before the license change still are).</li>\n<li><a href=\"https://commons.wikimedia.org/w/index.php?search=filetype%3Aimage+incategory%3A%22cc-zero%7CPD-user%7CCC-PD-Mark%7CPD-Art+%28PD-old%29%7CPD-Art+%28PD-old-100%29%7CPD-Art+%28PD-old+default%29%7CPD-Art+%28PD-old-100-1923%29%7CPD-Art+%28PD-old-70-1923%29%7CLibrary+of+Congress-no+known+copyright+restrictions%7Cpublic+domain%22&#x26;title=Special%3ASearch&#x26;go=Go\">Wikimedia Commons: PD search</a> - Millions of PD media (images, videos, sounds, ...).</li>\n</ul>\n<h2 id=\"licenses\" style=\"position:relative;\"><a href=\"#licenses\" aria-label=\"licenses permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Licenses</h2>\n<ul>\n<li><a href=\"https://choosealicense.com/licenses/cc0-1.0/\">CC0 1.0 Universal</a> - Full text and explanation of CC0 at Choose a License.</li>\n<li><a href=\"http://unlicense.org/\">Unlicense</a> - Template for disclaiming copyright monopoly interest in software you have written.</li>\n<li><a href=\"http://www.wtfpl.net/\">WTFPL</a> - PD-equivalent license (not actually public domain).</li>\n</ul>\n<h2 id=\"organizations\" style=\"position:relative;\"><a href=\"#organizations\" aria-label=\"organizations permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Organizations</h2>\n<ul>\n<li><a href=\"https://indieweb.org/IndieWebCamp:Copyrights\">IndieWeb</a> - People-focused alternative to the \"corporate web\", movement that provides advocacy and education to domain owners.</li>\n<li><a href=\"http://questioncopyright.org/\">QuestionCopyright.org</a> - Nonprofit organization that provides advocacy and education to help cultural producers embrace open distribution.</li>\n<li><a href=\"https://www.communia-association.org/\">Communia</a> - Nonprofit organization that advocates for policies that expand the public domain and increase access to and re-use of culture and knowledge.</li>\n</ul>\n<h2 id=\"related\" style=\"position:relative;\"><a href=\"#related\" aria-label=\"related permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Related</h2>\n<ul>\n<li><a href=\"https://creativecommons.org/\">Creative Commons</a> - Organization devoted to expanding the range of creative works available for others to build upon legally and to share.</li>\n<li><a href=\"https://okfn.org/\">Open Knowledge International</a> -  Organization whose mission is for everyone to have access to key information and the ability to use it freely.</li>\n</ul>\n<h2 id=\"resources\" style=\"position:relative;\"><a href=\"#resources\" aria-label=\"resources permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Resources</h2>\n<ul>\n<li><a href=\"https://www.anticopyright.com/\">Anti-Copyright</a> - Describes how intellectual property is not the same as material property.</li>\n<li><a href=\"http://praxeology.net/anticopyright.htm\">Anti-Copyright Resources</a> - Large list of essays against copyright.</li>\n<li><a href=\"https://creativecommons.org/share-your-work/public-domain/cc0/\">Creative Commons CC0</a> - About the CC0 public domain dedication.</li>\n<li><a href=\"http://kopimi.com/\">Kopimi</a> - Symbol showing that you want a work to be copied.</li>\n<li><a href=\"http://livelydays.com/\">Lively Days</a> - Vegan recipes.</li>\n<li><a href=\"https://thesafezoneproject.com/help/uncopyright/\">The Safe Zone Project</a> - Online resource for creating powerful, effective LGBTQ awareness and ally training workshops.</li>\n<li><a href=\"http://uncopyright.org/\">Uncopyright: All Rights Released</a> - Hub for the uncopyright movement, with lists of works, questions, answers, and other information.</li>\n</ul>\n<h2 id=\"software\" style=\"position:relative;\"><a href=\"#software\" aria-label=\"software permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Software</h2>\n<ul>\n<li><a href=\"http://sigilmaster.com/\">CanvasPaint</a> - Clone of Microsoft Paint in HTML, CSS, and JavaScript.</li>\n<li><a href=\"https://github.com/mawww/kakoune/blob/master/UNLICENSE\">Kakoune</a> - Text editor inspired by Vim that features multiple selections, a client-server window architecture, and primitives for text manipulation.</li>\n<li><a href=\"https://archive.org/search.php?query=possible-copyright-status%3A%28NOT_IN_COPYRIGHT%29%20OR%20licenseurl%3A%28%22http%3A%2F%2Fcreativecommons.org%2Fpublicdomain%2Fmark%2F1.0%2F%22%29%20OR%20licenseurl%3A%28%22https%3A%2F%2Fcreativecommons.org%2Fpublicdomain%2Fzero%2F1.0%2F%22%29\">Libregamewiki: PD Games</a> - Completely PD games.</li>\n<li><a href=\"https://luapower.com/\">Luapower</a> - Deploying and sharing Lua modules with a unique philosophy.</li>\n<li><a href=\"https://github.com/nothings/single_file_libs\">single_file_libs</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/nothings/single_file_libs\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">6.4k</span></span></a> - Many small PD libraries for programmers to use.</li>\n<li><a href=\"https://sqlite.org/copyright.html\">SQLite</a> - Embedded SQL database engine.</li>\n<li><a href=\"https://en.wikipedia.org/wiki/Category:Public-domain_software_with_source_code\">Wikipedia: PD software</a> - List of PD software on Wikipedia.</li>\n<li><a href=\"https://rg3.github.io/youtube-dl/about.html\">youtube-dl</a> - Command line program to download videos from YouTube and other video sites.</li>\n</ul>\n<h2 id=\"talks\" style=\"position:relative;\"><a href=\"#talks\" aria-label=\"talks permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Talks</h2>\n<ul>\n<li><a href=\"https://www.youtube.com/watch?v=7Q25-S7jzgs\">Laws That Choke Creativity</a> - Lawrence Lessig presents an argument for reviving our creative culture.</li>\n</ul>\n<h2 id=\"other\" style=\"position:relative;\"><a href=\"#other\" aria-label=\"other permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Other</h2>\n<ul>\n<li><a href=\"https://www.wikidata.org/wiki/Wikidata:Main_Page\">WikiData</a> - Huge amount of data about the world, released under CC0.</li>\n<li><a href=\"https://en.wikisource.org/wiki/The_Pig_and_the_Box\">The Pig and the Box</a> - Children book about the dangers of DRM, later released under CC0 (CC-BY-NC-SA no longer applies).</li>\n</ul>\n<h2 id=\"license\" style=\"position:relative;\"><a href=\"#license\" aria-label=\"license permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>License</h2>\n<p><a href=\"https://creativecommons.org/publicdomain/zero/1.0/\">CC0 1.0</a></p>","tableOfContents":"<ul>\n<li>\n<p><a href=\"#awesome-uncopyright-awesome\">Awesome Uncopyright <img src=\"https://cdn.rawgit.com/sindresorhus/awesome/d7305f38d29fed78fa85652e3a63e154dd8e8829/media/badge.svg\" alt=\"Awesome\"></a></p>\n<ul>\n<li><a href=\"#contents\">Contents</a></li>\n<li><a href=\"#art\">Art</a></li>\n<li><a href=\"#articles\">Articles</a></li>\n<li><a href=\"#blogs\">Blogs</a></li>\n<li><a href=\"#books\">Books</a></li>\n<li><a href=\"#essays\">Essays</a></li>\n<li><a href=\"#images\">Images</a></li>\n<li><a href=\"#licenses\">Licenses</a></li>\n<li><a href=\"#organizations\">Organizations</a></li>\n<li><a href=\"#related\">Related</a></li>\n<li><a href=\"#resources\">Resources</a></li>\n<li><a href=\"#software\">Software</a></li>\n<li><a href=\"#talks\">Talks</a></li>\n<li><a href=\"#other\">Other</a></li>\n<li><a href=\"#license\">License</a></li>\n</ul>\n</li>\n</ul>","headings":[{"id":"awesome-uncopyright-awesome","value":"Awesome Uncopyright Awesome","depth":1},{"id":"contents","value":"Contents","depth":2},{"id":"art","value":"Art","depth":2},{"id":"articles","value":"Articles","depth":2},{"id":"blogs","value":"Blogs","depth":2},{"id":"books","value":"Books","depth":2},{"id":"essays","value":"Essays","depth":2},{"id":"images","value":"Images","depth":2},{"id":"licenses","value":"Licenses","depth":2},{"id":"organizations","value":"Organizations","depth":2},{"id":"related","value":"Related","depth":2},{"id":"resources","value":"Resources","depth":2},{"id":"software","value":"Software","depth":2},{"id":"talks","value":"Talks","depth":2},{"id":"other","value":"Other","depth":2},{"id":"license","value":"License","depth":2}]},"awesomeList":{"repo":"johnjago/awesome-uncopyright","description":"Curated list of all things public domain","descriptionHTML":"<div>Curated list of all things public domain</div>"},"awesomeListMeta":{"readmeParsedAt":"2021-06-27T23:37:37.492Z"},"previous":{"id":"1aea2cec-095d-5976-9db7-a981f26af73e","fields":{"repo":"thomasbnt/awesome-web-monetization","slug":"/thomasbnt/awesome-web-monetization/readme/"}},"next":{"id":"62683151-1864-57ea-969d-6000e9173fee","fields":{"repo":"Zheaoli/awesome-coins","slug":"/Zheaoli/awesome-coins/readme/"}}},"pageContext":{"repo":"johnjago/awesome-uncopyright","id":"53433c0b-84ba-594e-b132-5924fdf61b9f","previousId":"1aea2cec-095d-5976-9db7-a981f26af73e","nextId":"62683151-1864-57ea-969d-6000e9173fee"}},"staticQueryHashes":["228695001","2744905544","3289010534"]}