{"componentChunkName":"component---src-templates-awesome-readme-js","path":"/matchai/awesome-pinned-gists/readme/","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"markdownRemark":{"id":"e95e5d44-ca20-5076-8fc6-f0bcc7836c50","html":"<p align=\"center\">\n  <img src=\"https://user-images.githubusercontent.com/4658208/57482610-14f64480-7273-11e9-862e-80d9fe332311.png\" width=\"535\">\n  </p><h3 align=\"center\">Awesome Pinned Gists</h3>\n  <p align=\"center\">A curated list of open source tools for adding dynamic data to pinned gists.</p><p>\n  </p><p align=\"center\">\n    <a href=\"https://awesome.re\"><img src=\"https://awesome.re/badge.svg\" alt=\"Awesome Lists\"></a>\n  </p>\n<p></p>\n<h2 id=\"contents\" style=\"position:relative;\"><a href=\"#contents\" aria-label=\"contents permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Contents</h2>\n<ul>\n<li><a href=\"#external-services\">External Services</a></li>\n<li><a href=\"#github\">GitHub</a></li>\n<li><a href=\"#resources\">Resources</a></li>\n</ul>\n<h2 id=\"external-services\" style=\"position:relative;\"><a href=\"#external-services\" aria-label=\"external services permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c