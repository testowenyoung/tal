{"componentChunkName":"component---src-templates-awesome-timeline-js","path":"/analyticalmonk/awesome-neuroscience/","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"awesomeList":{"repo":"analyticalmonk/awesome-neuroscience","descriptionHTML":"<div>A curated list of awesome neuroscience libraries, software and any content related to the domain.</div>","description":"A curated list of awesome neuroscience libraries, software and any content related to the domain."},"awesomeListMeta":{"readmeParsedAt":"2021-06-27T23:37:27.495Z"},"allAwesomeItem":{"nodes":[{"categoryHTML":"<h2>Programming</h2><h3>Matlab</h3>","itemHTML":"<li><a href=\"https://bdtoolbox.org/\">Brain Dynamics Toolbox</a> - Open software for simulating dynamical systems in neuroscience.</li>","updatedAt":"2021-06-02T13:21:41.000Z"},{"categoryHTML":"<h2>Programming</h2><h3>Matlab</h3>","itemHTML":"<li><a href=\"https://neuroimage.usc.edu/brainstorm/\">BrainStorm</a> - Open-source application dedicated to the analysis of brain recordings (MEG, EEG, fNIRS, ECoG, depth electrodes and multiunit electrophysiology).</li>","updatedAt":"2021-06-02T13:21:41.000Z"},{"categoryHTML":"<h2>Programming</h2><h3>Matlab</h3>","itemHTML":"<li><a href=\"https://sccn.ucsd.edu/eeglab/\">EEGLAB</a> - Interactive Matlab toolbox for processing continuous and event-related EEG, MEG and other electrophysiological data.</li>","updatedAt":"2021-06-02T13:21:41.000Z"},{"categoryHTML":"<h2>Programming</h2><h3>Matlab</h3>","itemHTML":"<li><a href=\"https://www.fil.ion.ucl.ac.uk/spm/\">SPM</a> - Free and open source software for the  analysis of brain imaging data sequences (fMRI, PET, SPECT, EEG, MEG).</li>","updatedAt":"2021-06-02T13:21:41.000Z"},{"categoryHTML":"<h2>Resources</h2><h3>MOOCs</h3>","itemHTML":"<li><a href=\"https://github.com/NeuromatchAcademy/course-content\">Neuromatch Academy</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/NeuromatchAcademy/course-content\" style=\"text-deco