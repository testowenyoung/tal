{"componentChunkName":"component---src-templates-awesome-timeline-js","path":"/TalAter/awesome-service-workers/week/","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"awesomeList":{"repo":"TalAter/awesome-service-workers","descriptionHTML":"<div>\n<g-emoji class=\"g-emoji\" alias=\"nut_and_bolt\" fallback-src=\"https://github.githubassets.com/images/icons/emoji/unicode/1f529.png\">🔩</g-emoji> A collection of awesome resources for learning Service Workers</div>","description":":nut_and_bolt: A collection of awesome resources for learning Service Workers"},"awesomeListMeta":{"readmeParsedAt":"2021-06-29T11:19:08.414Z"},"allAwesomeItem":{"nodes":[{"categoryHTML":"<h2>Libraries and Tools</h2>","itemHTML":"<li><a href=\"https://developers.google.com/web/updates/2016/07/offline-google-analytics\">sw-offline-google-analytics</a> - A service worker helper library to retry offline Google Analytics requests when a connection is available.</li>","updatedAt":"2018-10-30T20:22:27.000Z"},{"categoryHTML":"<h2>Libraries and Tools</h2>","itemHTML":"<li><a href=\"https://developers.google.com/web/tools/workbox/\">Workbox</a> - a set of libraries and Node modules that make it easy to cache assets and take full advantage of features used to build progressive web apps.</li>","updatedAt":"2018-05-17T16:03:59.000Z"},{"categoryHTML":"<h2>Must Reads</h2>","itemHTML":"<li><a href=\"http://www.html5rocks.com/en/tutorials/service-worker/introduction/\">Introduction to Service Worker</a> - A gentle introduction to service workers.</li>","updatedAt":"2017-09-11T16:32:37.000Z"},{"categoryHTML":"<h2>Must Reads</h2>","itemHTML":"<li><a href=\"https://pwabook.com/oreillyasw\">Building Progressive Web Apps - O'Reilly</a> - A hands-on guide and reference for service workers, caching strategies, push notifications, and more. Everything you need to build a modern progressive web app.</li>","updatedAt":"2016-09-13T10:20:24.000Z"},{"categoryHTML":"<h2>Must Reads</h2>","itemHTML":"<li><a href=\"https://www.udacity.com/course/offline-web-applications--ud899\">Offline Web Applications Using IndexedDB &#x26; Service Worker</a> - A great Udacity course introducing service workers and IndexedDB.</li>","updatedAt":"2016-09-13T10:20:24.000Z"},{"categoryHTML":"<h2>Learning Resources</h2>","itemHTML":"<li><a href=\"http://alistapart.com/article/offline-first\">Designing Offline-First Web Apps</a> - A fascinating look at design and UX considerations for dealing with various states of connectivity.</li>","updatedAt":"2016-09-13T10:20:24.000Z"},{"categoryHTML":"<h2>Related Technologies</h2>","itemHTML":"<li><a href=\"https://github.com/TalAter/awesome-progressive-web-apps#installable-web-apps\">App Install Banners</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/TalAter/awesome-progressive-web-apps#installable-web-apps\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">1.4k</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":1438,\"repo\":\"TalAter/awesome-progressive-web-apps\"}____TRACK_AWESOME_REPO_ITEM_END--></li>","updatedAt":"2016-08-26T22:24:18.000Z"},{"categoryHTML":"<h2>Related Technologies</h2>","itemHTML":"<li><a href=\"https://github.com/TalAter/awesome-progressive-web-apps#push-notifications\">Push Notifications</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/TalAter/awesome-progressive-web-apps#push-notifications\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size