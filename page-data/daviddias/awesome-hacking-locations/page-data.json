{"componentChunkName":"component---src-templates-awesome-timeline-js","path":"/daviddias/awesome-hacking-locations/","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"awesomeList":{"repo":"daviddias/awesome-hacking-locations","descriptionHTML":"<div>\n<g-emoji class=\"g-emoji\" alias=\"computer\" fallback-src=\"https://github.githubassets.com/images/icons/emoji/unicode/1f4bb.png\">💻</g-emoji> <g-emoji class=\"g-emoji\" alias=\"coffee\" fallback-src=\"https://github.githubassets.com/images/icons/emoji/unicode/2615.png\">☕</g-emoji> List of Awesome Hacking Locations, organised by Country and City, listing if it features power and wifi</div>","description":":computer: :coffee: List of Awesome Hacking Locations, organised by Country and City, listing if it features power and wifi"},"awesomeListMeta":{"readmeParsedAt":"2021-06-27T23:36:05.089Z"},"allAwesomeItem":{"nodes":[{"categoryHTML":"<h2>Tallinn</h2><h4><a href=\"https://k-space.ee/\">K-Space</a></h4>","itemHTML":"<li>Various equipment to print, engrave and cut (everything but yourself)</li>","updatedAt":"2020-09-25T16:34:18.000Z"},{"categoryHTML":"<h2>Tallinn</h2><h4><a href=\"https://k-space.ee/\">K-Space</a></h4>","itemHTML":"<li>Chaostreff weekly on Thursdays @ 18:00</li>","updatedAt":"2020-03-17T05:06:11.000Z"},{"categoryHTML":"<h2>Tallinn</h2><h4><a href=\"https://k-space.ee/\">K-Space</a></h4>","itemHTML":"<li>The only hackerspace with a server room (according to <a href=\"https://wiki.hackerspaces.org/K-space.ee\">hackerspaces.org</a>)</li>","updatedAt":"2020-03-17T05:06:11.000Z"},{"categoryHTML":"<h2>Tallinn</h2><h4><a href=\"https://k-space.ee/\">K-Space</a></h4>","itemHTML":"<li>Bees, honey</li>","updatedAt":"2020-03-17T05:06:11.000Z"},{"categoryHTML":"<h2>Tallinn</h2><h4><a href=\"https://k-space.ee/\">K-Space</a></h4>","itemHTML":"<li>Quiet office, if you don't have time for fun</li>","updatedAt":"2020-03-17T05:06:11.000Z"},{"categoryHTML":"<h2>Massachusetts </h2><h4>Diesel Cafe</h4>","itemHTML":"<li>Contact <a href=\"https://twitter.com/richlitt\">@richlitt</a> for wifi password if needed.</li>","updatedAt":"2017-10-11T17:22:50.000Z"},{"categoryHTML":"<h2>Massachusetts </h2><h4>Diesel Cafe</h4>","itemHTML":"<li>You get 45m of free wifi per day. More if you know what you're doing ;) (but $14/mo for wifi is worth it if you hack there often)</li>","updatedAt":"2017-10-11T17:22:50.000Z"},{"categoryHTML":"<h2>Massachusetts </h2><h4>Diesel Cafe</h4>","itemHTML":"<li>Using IPFS will get you kicked off their network in ~2hr (FYI).</li>","updatedAt":"2017-10-11T17:22:50.000Z"},{"categoryHTML":"<h2>Hackerspaces</h2>","itemHTML":"<li><a href=\"https://wiki.hackerspaces.org/List_of_Hacker_Spaces\">https://wiki.hackerspaces.org/List_of_Hacker_Spaces</a></li>","updatedAt":"2016-01-13T19:32:55.000Z"}]},"previous":{"id":"awesomes/github.com/hobbyquaker/awesome-mqtt","repo":"hobbyquaker/awesome-mqtt"},"next":{"id":"awesomes/github.com/cristianoliveira/awesome4girls","repo":"cristianoliveira/awesome4girls"}},"pageContext":{"repo":"daviddias/awesome-hacking-locations","id":"awesomes/github.com/daviddias/awesome-hacking-locations","previousId":"awesomes/github.com/hobbyquaker/awesome-mqtt","nextId":"awesomes/github.com/cristianoliveira/awesome4girls"}},"staticQueryHashes":["228695001","2744905544","3289010534"]}