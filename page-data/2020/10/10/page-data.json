{"componentChunkName":"component---src-templates-awesome-all-timeline-js","path":"/2020/10/10/","result":{"data":{"site":{"siteMetadata":{"title":"Track Awesome List"}},"allAwesomeItem":{"nodes":[{"awesomeListRepo":"sdras/awesome-actions","categoryHTML":"<h2>Community Resources</h2><h3>Pull Requests</h3>","itemHTML":"<li><a href=\"https://github.com/derkinderfietsen/pr-description-enforcer\">Pull Request Description Enforcer</a> - Enforces description on pull requests.</li>","updatedAt":"2020-10-10T22:31:29.000Z"},{"awesomeListRepo":"awesome-selfhosted/awesome-selfhosted","categoryHTML":"<h2>Software</h2><h3>Communication - Social Networks and Forums</h3>","itemHTML":"<li><a href=\"https://gnu.io/social/\">GNU social</a> - Social communication software for both public and private communications. (<a href=\"https://notabug.org/diogo/gnu-social\">Source Code</a>) <code>AGPL-3.0</code> <code>PHP</code></li>","updatedAt":"2020-10-10T19:21:03.000Z"},{"awesomeListRepo":"EbookFoundation/free-programming-books","categoryHTML":"<h3>Embedded Systems</h3>","itemHTML":"<li><a href=\"https://www.phaedsys.com/principals/bytecraft/bytecraftdata/bcfirststeps.pdf\">First Steps with Embedded Systems</a> - Byte Craft Limited (PDF)</li>","updatedAt":"2020-10-10T19:18:13.000Z"},{"awesomeListRepo":"EbookFoundation/free-programming-books","categoryHTML":"<h3>R</h3>","itemHTML":"<li><a href=\"https://csgillespie.github.io/efficientR/\">Efficient R programming</a> - Colin Gillespie, Robin Lovelace</li>","updatedAt":"2020-10-10T18:42:45.000Z"},{"awesomeListRepo":"EbookFoundation/free-programming-books","categoryHTML":"<h3>R</h3>","itemHTML":"<li><a href=\"https://learningstatisticswithr.com/book/\">Learning Statistics with R</a> - Danielle Navarro</li>","updatedAt":"2020-10-10T18:40:10.000Z"},{"awesomeListRepo":"sdassow/awesome-veganism","categoryHTML":"<h2>Bakeries</h2>","itemHTML":"<li>Monster, Netherlands\n<ul>\n<li><a href=\"https://macarononline-nl.mijndomeinwebwinkel.nl/\">My Cakes</a> - Amazing selection of cakes, macarons, dutch specialties, and more.</li>\n</ul>\n</li>","updatedAt":"2020-10-10T17:47:00.000Z"},{"awesomeListRepo":"sdassow/awesome-veganism","categoryHTML":"<h2>Bakeries</h2>","itemHTML":"<li>Zaandijk, Netherlands\n<ul>\n<li><a href=\"https://www.veganbakery.nl/\">Vegan bakery</a> - Dutch vegan bakery with a big selection of vegan cakes, muffins, and other awesomeness.</li>\n</ul>\n</li>","updatedAt":"2020-10-10T17:47:00.000Z"},{"awesomeListRepo":"sdassow/awesome-veganism","categoryHTML":"<h2>Restaurants</h2>","itemHTML":"<li>Amsterdam, Netherlands\n<ul>\n<li><a href=\"https://deermama.nl/\">Deer Mama</a> - Mylkshakes, burgers, nice food, and colorful cakes.</li>\n<li><a href=\"https://koffieendekoeck.nl/\">Koffie Ende Koeck</a> - Small vegan cafe, with nice brunch, and awesome vegan high tea.</li>\n<li><a href=\"https://www.facebook.com/lovinghutamsterdam\">Loving Hut</a> - Cozy and family friendly with Asian kitchen and some dutch classics.</li>\n<li><a href=\"https://www.mooshka.nl/\">Mooshka</a> - Stylish place with nice atmosphere, and a great variety of tasty dishes and drinks.</li>\n<li><a href=\"https://watsonsfood.com/\">Mr. &#x26; Mrs. Watson</a> - Relaxed atmosphere, nice drinks, and great dishes.</li>\n<li><a href=\"http://terrazencentre.com/\">TerraZen Centre</a> - Chill vibe and mouth-watering dishes with Caribbean and Japanese influence, really close to central station.</li>\n<li><a href=\"https://www.trevisamsterdam.nl/\">Trevi's Plant Based Italian Food</a> - Cozy Italian, lovely vibe, amazing and authentic food, feels and tastes like in Italy.</li>\n<li><a href=\"https://www.veganjunkfoodbar.com/\">Vegan Junk Food Bar</a> - High quality burgers, fancy hotdogs, Dutch specialties like Bitterballen, cocktails, and more.</li>\n<li><a href=\"https://yemaya.estate/\">Yemayá's Vegan Corner</a> - Super tasty food driven by sustainable local community efforts.</li>\n</ul>\n</li>","updatedAt":"2020-10-10T17:47:00.000Z"},{"awesomeListRepo":"sdassow/awesome-veganism","categoryHTML":"<h2>Restaurants</h2>","itemHTML":"<li>Bonn, Germany\n<ul>\n<li><a href=\"https://kaiserhuettn.com/\">Kaiserhüttn</a> - Eat like in Austria.</li>\n</ul>\n</li>","updatedAt":"2020-10-10T17:47:00.000Z"},{"awesomeListRepo":"sdassow/awesome-veganism","categoryHTML":"<h2>Restaurants</h2>","itemHTML":"<li>Eindhoven, Netherlands\n<ul>\n<li><a href=\"https://www.bistrocalypso.nl/\">Bar Bistro Calypso</a> - Cosiest livingroom in town, with tasty no-nonsense dishes and good drinks.</li>\n<li><a href=\"https://www.bijalbrecht.nl/\">Bij Albrecht</a> - Vegan and organic food experience with seasonal produce.</li>\n<li><a href=\"https://www.junglecafecatering.nl\">Jungle Café &#x26; Catering</a> - Vegan coffeebar &#x26; lunchroom for young and old. Also offers catering &#x26; take away.</li>\n<li><a href=\"https://veganheroes.nl/\">Vegan Heroes</a> - Great vegan fast food, smoothie bowls, snacks, and desserts.</li>\n</ul>\n</li>","updatedAt":"2020-10-10T17:47:00.000Z"},{"awesomeListRepo":"sdassow/awesome-veganism","categoryHTML":"<h2>Restaurants</h2>","itemHTML":"<li>Köln, Germany\n<ul>\n<li><a href=\"https://www.sattgruen.com/\">Sattgrün</a> - Buffet with great varieity and quality.</li>\n</ul>\n</li>","updatedAt":"2020-10-10T17:47:00.000Z"},{"awesomeListRepo":"sdassow/awesome-veganism","categoryHTML":"<h2>Restaurants</h2>","itemHTML":"<li>London, UK\n<ul>\n<li><a href=\"https://eatbychloe.com/\">Eat By Cloe</a> - For the mandatory fish and chips this place is definitely worth visiting.</li>\n</ul>\n</li>","updatedAt":"2020-10-10T17:47:00.000Z"},{"awesomeListRepo":"sdassow/awesome-veganism","categoryHTML":"<h2>Restaurants</h2>","itemHTML":"<li>Oakland, USA\n<ul>\n<li><a href=\"https://www.millenniumrestaurant.com/\">Millennium Restaurant</a> - Far cry from your ordinary vegan spot in that it takes a hands on, from scratch approach to food which assures a fresh, local, organic and homemade product every time.</li>\n</ul>\n</li>","updatedAt":"2020-10-10T17:47:00.000Z"},{"awesomeListRepo":"sdassow/awesome-veganism","categoryHTML":"<h2>Restaurants</h2>","itemHTML":"<li>Utrecht, Netherlands\n<ul>\n<li><a href=\"https://www.oproerbrouwerij.nl/\">Oproer</a> - Local brewery with tasty beers and vegan street food.</li>\n</ul>\n</li>","updatedAt":"2020-10-10T17:47:00.000Z"},{"awesomeListRepo":"EbookFoundation/free-programming-books","categoryHTML":"<h3>Linux</h3>","itemHTML":"<li><a href=\"http://linux-training.be/linuxfun.pdf\">Linux Fundamentals</a> - Paul Cobbaut (PDF)</li>","updatedAt":"2020-10-10T17:39:07.000Z"},{"awesomeListRepo":"EbookFoundation/free-programming-books","categoryHTML":"<h4>Phoenix</h4>","itemHTML":"<li><a href=\"https://hexdocs.pm/phoenix/overview.html\">Phoenix Framework Guide</a> (HTML)</li>","updatedAt":"2020-10-10T17:38:18.000Z"},{"awesomeListRepo":"EbookFoundation/free-programming-books","categoryHTML":"<h3>Erlang</h3>","itemHTML":"<li><a href=\"http://beam-wisdoms.clau.se/en/latest/\">BEAM Wisdoms</a> (HTML)</li>","updatedAt":"2020-10-10T17:37:12.000Z"},{"awesomeListRepo":"EbookFoundation/free-programming-books","categoryHTML":"<h3>Erlang</h3>","itemHTML":"<li><a href=\"https://blog.stenmans.org/theBeamBook\">The BEAM Book</a> (HTML)</li>","updatedAt":"2020-10-10T17:37:12.000Z"},{"awesomeListRepo":"vuejs/awesome-vue","categoryHTML":"<h2>Resources</h2><h3>Tutorials</h3>","itemHTML":"<li><a href=\"https://www.youtube.com/watch?v=ZqgiuPt5QZo&#x26;ab_channel=TheEarthisSquare\">Learn Vue 3 for Beginners - Full 2020 Tutorial Course</a> on Youtube</li>","updatedAt":"2020-10-10T17:22:20.000Z"},{"awesomeListRepo":"awesome-foss/awesome-sysadmin","categoryHTML":"<h2>Continuous Integration &#x26; Continuous Deployment</h2>","itemHTML":"<li><a href=\"https://ovh.github.io/cds/\">CDS</a> - Enterprise-Grade Continuous Delivery &#x26; DevOps Automation Open Source Platform  (<a href=\"https://github.com/ovh/cds\">Source Code</a><a data-role=\"trackawesomelist-badge\" href=\"https