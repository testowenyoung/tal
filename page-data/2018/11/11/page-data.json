 run:\n\n> git signatures show\n</code></pre>","updatedAt":"2018-11-11T03:02:07.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/hashbang/git-signatures\">git-signatures</a></h2>","itemHTML":"<h3>signatures show</h3>\n<pre><code>$ git signatures show v1.0.0\n Public Key ID    | Status     | Trust     | Date                         | Signer Name\n=======================================================================================================================\n01234567890ABCDEF | VALIDSIG   | ULTIMATE  | Sat Nov 10 13:16:10 EST 2018 | Steve Mao &#x3C;maochenyan@gmail.com>\n</code></pre>","updatedAt":"2018-11-11T03:02:07.000Z"},{"awesomeListRepo":"vert-x3/vertx-awesome","categoryHTML":"<h2>Books</h2>","itemHTML":"<li><a href=\"https://www.manning.com/books/vertx-in-action\">Vert.x in Action</a> by Julien Ponge</li>","updatedAt":"2018-11-11T02:17:14.000Z"}]}},"pageContext":{"type":"day","from":1541894400000,"to":1541980799999,"previousId":"2018-11-12","nextId":"2018-11-10","nextName":"Nov 10th, 2018","previousName":"Nov 12th, 2018"}},"staticQueryHashes":["228695001","2744905544","2828988102"]}