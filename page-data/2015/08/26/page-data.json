/mislav/git-deploy\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">2.1k</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":2102,\"repo\":\"mislav/git-deploy\"}____TRACK_AWESOME_REPO_ITEM_END--></h2>\n<pre><code>$ git remote add production \"user@example.com:/apps/mynewapp\"\n$ git deploy setup -r \"production\"\n$ git deploy init\n$ git push production master\n</code></pre>","updatedAt":"2015-08-26T07:04:20.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>clone</h3>\n<pre><code>$ git clone schacon/ticgit\n> git clone git://github.com/schacon/ticgit.git\n\n$ git clone -p schacon/ticgit\n> git clone git@github.com:schacon/ticgit.git\n\n$ git clone resque\n> git clone git@github.com/YOUR_USER/resque.git\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>remote add</h3>\n<pre><code>$ git remote add rtomayko\n> git remote add rtomayko git://github.com/rtomayko/CURRENT_REPO.git\n\n$ git remote add -p rtomayko\n> git remote add rtomayko git@github.com:rtomayko/CURRENT_REPO.git\n\n$ git remote add origin\n> git remote add origin git://github.com/YOUR_USER/CURRENT_REPO.git\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>fetch</h3>\n<pre><code>$ git fetch mislav\n> git remote add mislav git://github.com/mislav/REPO.git\n> git fetch mislav\n\n$ git fetch mislav,xoebus\n> git remote add mislav ...\n> git remote add xoebus ...\n> git fetch --multiple mislav xoebus\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>cherry-pick</h3>\n<pre><code>$ git cherry-pick https://github.com/mislav/REPO/commit/SHA\n> git remote add -f --no-tags mislav git://github.com/mislav/REPO.git\n> git cherry-pick SHA\n\n$ git cherry-pick mislav@SHA\n> git remote add -f --no-tags mislav git://github.com/mislav/CURRENT_REPO.git\n> git cherry-pick SHA\n\n$ git cherry-pick mislav@SHA\n> git fetch mislav\n> git cherry-pick SHA\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>am</h3>\n<pre><code>$ git am https://github.com/github/hub/pull/55\n[ downloads patch via API ]\n> git am /tmp/55.patch\n\n$ git am --ignore-whitespace https://github.com/davidbalbert/hub/commit/fdb9921\n[ downloads patch via API ]\n> git am --ignore-whitespace /tmp/fdb9921.patch\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>apply</h3>\n<pre><code>$ git apply https://gist.github.com/8da7fb575debd88c54cf\n[ downloads patch via API ]\n> git apply /tmp/gist-8da7fb575debd88c54cf.txt\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>fork</h3>\n<pre><code>$ git fork\n[ repo forked on GitHub ]\n> git remote add -f YOUR_USER git@github.com:YOUR_USER/CURRENT_REPO.git\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>pull-request</h3>\n<pre><code>$ git pull-request\n[ opens text editor to edit title &#x26; body for the request ]\n[ opened pull request on GitHub for \"YOUR_USER:feature\" ]\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>checkout</h3>\n<pre><code>$ git checkout https://github.com/github/hub/pull/73\n> git remote add -f --no-tags -t feature mislav git://github.com/mislav/hub.git\n> git checkout --track -B mislav-feature mislav/feature\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>merge</h3>\n<pre><code>$ git merge https://github.com/github/hub/pull/73\n> git fetch git://github.com/mislav/hub.git +refs/heads/feature:refs/remotes/mislav/feature\n> git merge mislav/feature --no-ff -m 'Merge pull request #73 from mislav/feature...'\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>create</h3>\n<pre><code>$ git create\n[ repo created on GitHub ]\n> git remote add origin git@github.com:YOUR_USER/CURRENT_REPO.git\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>init</h3>\n<pre><code>$ git init -g\n> git init\n> git remote add origin git@github.com:YOUR_USER/REPO.git\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>push</h3>\n<pre><code>$ git push origin,staging,qa bert_timeout\n> git push origin bert_timeout\n> git push staging bert_timeout\n> git push qa bert_timeout\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>browse</h3>\n<pre><code>$ git browse\n> open https://github.com/YOUR_USER/CURRENT_REPO\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>compare</h3>\n<pre><code>$ git compare refactor\n> open https://github.com/CURRENT_REPO/compare/refactor\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>submodule</h3>\n<pre><code>$ git submodule add wycats/bundler vendor/bundler\n> git submodule add git://github.com/wycats/bundler.git vendor/bundler\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/github/hub\">hub</a></h2>","itemHTML":"<h3>ci-status</h3>\n<pre><code>$ git ci-status\nsuccess\n</code></pre>","updatedAt":"2015-08-26T06:42:32.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/petervanderdoes/gitflow-avh\">gitflow (AVH Edition)</a></h2>","itemHTML":"<h3>flow feature</h3>\n<pre><code>$ git flow feature\n$ git flow feature start awesome-feature\n$ git flow feature finish awesome-feature\n$ git flow feature delete awesome-feature\n\n$ git flow feature publish awesome-feature\n$ git flow feature pull remote awesome-feature\n</code></pre>","updatedAt":"2015-08-26T06:22:21.000Z"},{"awesomeListRepo":"stevemao/awesome-git-addons","categoryHTML"