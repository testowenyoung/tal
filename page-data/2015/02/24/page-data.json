 4px;border-bottom-right-radius: 4px;\">16.5k</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":16512,\"repo\":\"dotnet/roslyn\"}____TRACK_AWESOME_REPO_ITEM_END--> - The .NET Compiler Platform (\"Roslyn\") provides open-source C# and Visual Basic compilers with rich code analysis APIs. It enables building code analysis tools with the same APIs that are used by Visual Studio.</li>","updatedAt":"2015-02-24T13:28:36.000Z"},{"awesomeListRepo":"quozd/awesome-dotnet","categoryHTML":"<h2>Office</h2>","itemHTML":"<li><a href=\"https://github.com/officedev/open-xml-sdk\">Open XML SDK</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/officedev/open-xml-sdk\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">3.3k</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":3296,\"repo\":\"officedev/open-xml-sdk\"}____TRACK_AWESOME_REPO_ITEM_END--> - The Open XML SDK provides open-source libraries for working with Open XML Documents (DOCX, XLSX, and PPTX).</li>","updatedAt":"2015-02-24T13:07:18.000Z"},{"awesomeListRepo":"quozd/awesome-dotnet","categoryHTML":"<h2>Visual Studio Plugins</h2>","itemHTML":"<li><a href=\"https://github.com/Microsoft/CodeContracts\">CodeContracts</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/Microsoft/CodeContracts\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">871</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":871,\"repo\":\"Microsoft/CodeContracts\"}____TRACK_AWESOME_REPO_ITEM_END--> - Source code for the CodeContracts tools for .NET</li>","updatedAt":"2015-02-24T13:07:18.000Z"},{"awesomeListRepo":"phanan/htaccess","categoryHTML":"<h2>Security</h2>","itemHTML":"<h3>Block Visitors by Referrer</h3>\n<p>This denies access for all users who are coming from (referred by) a specific domain.\n<a href=\"http://www.htaccess-guide.com/deny-visitors-by-referrer/\">Source</a></p>\n<pre><code class=\"language-apacheconf\">RewriteEngine on\n# Options +FollowSymlinks\nRewriteCond %{HTTP_REFERER} somedomain\\.com [NC,OR]\nRewriteCond %{HTTP_REFERER} anotherdomain\\.com\nRewriteRule .* - [F]\n</code></pre>","updatedAt":"2015-02-24T09:10:19.000Z"},{"awesomeListRepo":"phanan/htaccess","categoryHTML":"<h2>Security</h2>","itemHTML":"<h3>Prevent Framing the Site</h3>\n<p>This prevents the website to be framed (i.e. put into an <code>iframe</code> tag), when still allows framing for a specific URI.</p>\n<pre><code class=\"language-apacheconf\">SetEnvIf Request_URI \"/starry-night\" allow_framing=true\nHeader set X-Frame-Options SAMEORIGIN env=!allow_framing\n</code></pre>","updatedAt":"2015-02-24T09:10:19.000Z"}]}},"pageContext":{"type":"day","from":1424736000000,"to":1424822399999,"previousId":"2015-02-25","nextId":"2015-02-23","nextName":"Feb 23rd, 2015","previousName":"Feb 25th, 2015"}},"staticQueryHashes":["228695001","2744905544","2828988102"]}