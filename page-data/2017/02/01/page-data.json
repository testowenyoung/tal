o/awesome-git-addons","categoryHTML":"<h2><a href=\"https://github.com/Fakerr/git-recall\">git-recall</a></h2>","itemHTML":"<h2><a href=\"https://github.com/Fakerr/git-recall\">git-recall</a><a data-role=\"trackawesomelist-badge\" href=\"https://github.com/Fakerr/git-recall\" style=\"text-decoration:none;top: -2px;position: relative;margin-left:4px;margin-right:4px;font-weight:400;\"><span style=\"color: #fff;font-size: 11px;font-family: Verdana, Geneva, DejaVu Sans,sans-serif;\"><span style=\"padding:4px 4px 4px 6px;background: #555;border-top-left-radius: 4px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">2.1k</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":2113,\"repo\":\"Fakerr/git-recall\"}____TRACK_AWESOME_REPO_ITEM_END--></h2>\n<p><img src=\"https://camo.githubusercontent.com/eb306717b95724c33dd0de91faa535a4818cc7d0/687474703a2f2f696d6775722e636f6d2f7a7577324c71572e676966\" alt=\"\"></p>\n<pre><code>$ git recall\n# By default (without options), the command will display commits from yesterday and\n# for the current user.\n\n$ git recall -d 5 -a \"Doge\"\n# Show all Doge's commits from 5 days ago.\n\n$ git recall -d 5 -a \"all\"\n# Show commits of all contributors from 5 days ago.\n\n$ git recall -f\n# Fetch commits beforehand.\n</code></pre>","updatedAt":"2017-02-01T02:12:18.000Z"}]}},"pageContext":{"type":"day","from":1485907200000,"to":1485993599999,"previousId":"2017-02-02","nextId":"2017-01-31","nextName":"Jan 31st, 2017","previousName":"Feb 2nd, 2017"}},"staticQueryHashes":["228695001","2744905544","2828988102"]}