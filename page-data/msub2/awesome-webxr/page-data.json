px;border-bottom-left-radius: 4px;\">stars</span><span style=\"padding: 4px 6px 4px 4px;background: #007ec6;border-top-right-radius: 4px;border-bottom-right-radius: 4px;\">3</span></span></a><!--TRACK_AWESOME_REPO_ITEM_START____{\"type\":\"repo\",\"stargazerCount\":3,\"repo\":\"msub2/avatars\"}____TRACK_AWESOME_REPO_ITEM_END-->.</li>","updatedAt":"2022-05-07T22:22:03.000Z"},{"categoryHTML":"<h2>YouTube</h2>","itemHTML":"<li><a href=\"https://youtube.com/sorskoot\">Sorskoot</a> - Tutorials and other WebXR related content.</li>","updatedAt":"2022-05-07T22:17:41.000Z"},{"categoryHTML":"<h2>Content Hubs</h2>","itemHTML":"<li><a href=\"https://extendedcollection.com/\">Extended Collection</a> - Another curation hub for WebXR content maintained by <a href=\"https://github.com/vrhermit/\">Joseph Simpson</a>.</li>","updatedAt":"2022-05-07T21:39:44.000Z"},{"categoryHTML":"<h2>Standout Projects</h2>","itemHTML":"<li><a href=\"https://www.prehistoricdomain.com/\">Prehistoric Domain</a> - A Jurassic Park-esque experience in the browser, with multiple dinosaur exhibits available and more planned for the future.</li>","updatedAt":"2022-05-07T21:37:37.000Z"},{"categoryHTML":"<h2>Companies and Cooperatives</h2>","itemHTML":"<li><a href=\"https://web.immers.space/\">Immers Space</a> - A Distributed Cooperative Organization (DisCO) focused on enabling open and federated immersive web content.</li>","updatedAt":"2022-05-07T21:35:39.000Z"},{"categoryHTML":"<h2>Standout Projects</h2>","itemHTML":"<li><a href=\"https://plockle.com/\">Plockle</a> - A spatial block puzzle game with over 40 levels.</li>","updatedAt":"2022-01-30T21:46:44.000Z"},{"categoryHTML":"<h2>Standout Projects</h2>","itemHTML":"<li><a href=\"https://castle.needle.tools/\">Castle Builder</a> - A collaborative and cross-platform castle-building game utilizing a unique Unity-to-three.js pipeline.</li>","updatedAt":"2022-01-30T21:46:44.000Z"},{"categoryHTML":"<h2>Companies and Cooperatives</h2>","itemHTML":"<li><a href=\"h